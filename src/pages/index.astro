---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedDatabaseCollection from '../components/FeaturedDatabaseCollection.astro';
import { getHeroCarouselArtworks } from '../data/artworks';
import { brandName, defaultDescription, heroDescription } from '../data/meta';

const base = import.meta.env.BASE_URL;
const artistImage = `${base}artist.jpeg?v=1`;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || base.replace(/\/$/, '');
const supabaseUrl = 'https://sbbmducevhpirnthzvtz.supabase.co';
const supabaseKey = 'sb_publishable_X1bha7SOQmNtwVvC4Rhp-Q_67c3guiX';

const heroCarouselArtworks = getHeroCarouselArtworks();
const heroCarouselImages = heroCarouselArtworks.map((a) => ({ src: `${base}art/${a.image}`, alt: a.title }));
---
<Layout title="Home" description={defaultDescription}>
  <Hero
    images={heroCarouselImages}
    profileImageUrl={artistImage}
    heroDescription={heroDescription}
    base={base}
    currentPath={currentPath}
  />

  <FeaturedDatabaseCollection base={base} supabaseUrl={supabaseUrl} supabaseKey={supabaseKey} />

  <section class="about-artist" id="about-artist">
    <div class="about-artist__inner">
      <div class="about-artist__image-wrap">
        <img src={artistImage} alt={`${brandName} — artist`} class="about-artist__image" width="600" height="720" />
      </div>
      <div class="about-artist__content">
        <p class="about-artist__label">About the artist</p>
        <h2 class="about-artist__name">{brandName}</h2>
        <div class="about-artist__bio">
          <p>A multidisciplinary artist working across digital and traditional media. My work is a fusion of beauty and decay where memory distorts, color melts, and identity fractures into surreal, living artifacts.</p>
          <p>Each piece explores nostalga, time, and transformation while capturing fleeting moments between the synthetic and the human, where emotion becomes image. a texture remembered in childhood, a feeling without a name and where intuition and technique negotiate in the dark.</p>
        </div>
        <div class="about-artist__stats">
          <div class="about-artist__stat">
            <span class="about-artist__stat-num" data-target="25" data-suffix="+">0</span>
            <span class="about-artist__stat-label">Professional Years</span>
          </div>
          <div class="about-artist__stat">
            <span class="about-artist__stat-num" data-target="30" data-suffix="+">0</span>
            <span class="about-artist__stat-label">Companies & Brands</span>
          </div>
          <div class="about-artist__stat">
            <span class="about-artist__stat-num" data-target="15" data-suffix="+">0</span>
            <span class="about-artist__stat-label">Exhibitions</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="commission-cta">
    <h2 class="section-title">Commission & contact</h2>
    <p>Custom AI art, UX/IA consulting, or Lab tooling. <a href="mailto:toxiqmynd@gmail.com">Get in touch →</a></p>
  </section>

  <style>
    :global(main img),
    :global(main video) {
      height: 100%;
      object-fit: cover;
    }
  </style>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    /* Hero text/slideshow/scroll are handled in Hero.astro (CDN GSAP + ScrollTrigger) */

    const about = document.querySelector('.about-artist');
    if (about) {
      const imgWrap = about.querySelector('.about-artist__image-wrap');
      const content = about.querySelector('.about-artist__content');
      gsap.set(imgWrap, { opacity: 0, x: -56 });
      gsap.set(content, { opacity: 0, x: 56 });
      ScrollTrigger.create({
        trigger: about,
        start: 'top 78%',
        onEnter: () => {
          gsap.to(imgWrap, { opacity: 1, x: 0, duration: 0.85, ease: 'power2.out' });
          gsap.to(content, { opacity: 1, x: 0, duration: 0.85, ease: 'power2.out' });
        },
        once: true,
      });
    }
  </script>
  <script>
    function initCountUp() {
      const section = document.querySelector('.about-artist');
      if (!section) return;
      const nums = section.querySelectorAll('.about-artist__stat-num');
      const duration = 1500;
      const easeOutQuart = (t) => 1 - Math.pow(1 - t, 4);
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.disconnect();
          nums.forEach((el) => {
            const target = Number(el.dataset.target) || 0;
            const suffix = el.dataset.suffix || '';
            const start = performance.now();
            const step = (now) => {
              const elapsed = now - start;
              const p = Math.min(elapsed / duration, 1);
              const value = Math.floor(easeOutQuart(p) * target);
              el.textContent = value + suffix;
              if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
        });
      }, { threshold: 0.25 });
      observer.observe(section);
    }
    initCountUp();
  </script>
</Layout>
