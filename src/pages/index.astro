---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedCollection from '../components/FeaturedCollection.astro';
import ArtCard from '../components/ArtCard.astro';
import { getFeaturedArtworks, getArtworksBySeries, getHomepageHeroArtwork } from '../data/artworks';
import { brandName, defaultDescription, heroDescription } from '../data/meta';

const featured = getFeaturedArtworks(7);
const recentArt = getArtworksBySeries('fragment').slice(0, 4);
const base = import.meta.env.BASE_URL;
const artistImage = `${base}artist.jpeg?v=1`;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || base.replace(/\/$/, '');

const heroArtwork = getHomepageHeroArtwork();
const heroImage = heroArtwork
  ? { src: `${base}art/${heroArtwork.image}`, alt: heroArtwork.title }
  : null;
---
<Layout title="Home" description={defaultDescription}>
  <Hero
    image={heroImage}
    profileImageUrl={artistImage}
    heroDescription={heroDescription}
    base={base}
    currentPath={currentPath}
  />

  <FeaturedCollection artworks={featured} base={base} />

  <section>
    <h2 class="section-title">Recent work</h2>
    <ul class="gallery-grid">
      {recentArt.map((artwork) => (
        <ArtCard artwork={artwork} base={base} />
      ))}
    </ul>
    <div class="recent-links">
      <a href={`${base}work/`}>Work</a> — <a href={`${base}work/ai-art/`}>AI Art</a>, <a href={`${base}work/music/`}>Music</a>, <a href={`${base}work/ux/`}>UI/UX</a> · <a href={`${base}lab/`}>Lab</a>
    </div>
  </section>

  <section class="about-artist" id="about-artist">
    <div class="about-artist__inner">
      <div class="about-artist__image-wrap">
        <img src={artistImage} alt={`${brandName} — artist`} class="about-artist__image" width="600" height="720" />
      </div>
      <div class="about-artist__content">
        <p class="about-artist__label">About the artist</p>
        <h2 class="about-artist__name">{brandName}</h2>
        <div class="about-artist__bio">
          <p>A multidisciplinary artist working across digital and traditional media. My work investigates the tension between the constructed and the organic—light as material, shadow as language.</p>
          <p>Each piece begins with observation—a quality of light through glass, a texture remembered in childhood, a feeling without a name. The studio is a laboratory where intuition and technique negotiate in the dark.</p>
        </div>
        <div class="about-artist__stats">
          <div class="about-artist__stat">
            <span class="about-artist__stat-num" data-target="120" data-suffix="+">0</span>
            <span class="about-artist__stat-label">Years creating</span>
          </div>
          <div class="about-artist__stat">
            <span class="about-artist__stat-num" data-target="201" data-suffix="+">0</span>
            <span class="about-artist__stat-label">Works created</span>
          </div>
          <div class="about-artist__stat">
            <span class="about-artist__stat-num" data-target="30" data-suffix="+">0</span>
            <span class="about-artist__stat-label">Exhibitions</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="commission-cta">
    <h2 class="section-title">Commission & contact</h2>
    <p>Custom AI art, UX/IA consulting, or Lab tooling. <a href={`${base}contact/`}>Get in touch →</a></p>
  </section>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    /* Hero text/slideshow/scroll are handled in Hero.astro (CDN GSAP + ScrollTrigger) */

    const featuredCells = document.querySelectorAll('.featured-cell');
    if (featuredCells.length) {
      gsap.set(featuredCells, { opacity: 0, y: 32 });
      ScrollTrigger.create({
        trigger: '.featured-collection',
        start: 'top 85%',
        onEnter: () => {
          gsap.to(featuredCells, {
            opacity: 1,
            y: 0,
            duration: 0.7,
            stagger: 0.06,
            ease: 'power2.out',
          });
        },
        once: true,
      });
    }

    document.querySelectorAll('.gallery-grid').forEach((grid) => {
      const cards = grid.querySelectorAll('.art-card');
      gsap.set(cards, { opacity: 0, y: 40 });
      ScrollTrigger.create({
        trigger: grid,
        start: 'top 88%',
        onEnter: () => {
          gsap.to(cards, { opacity: 1, y: 0, duration: 0.65, stagger: 0.07, ease: 'power2.out' });
        },
        once: true,
      });
    });

    const about = document.querySelector('.about-artist');
    if (about) {
      const imgWrap = about.querySelector('.about-artist__image-wrap');
      const content = about.querySelector('.about-artist__content');
      gsap.set(imgWrap, { opacity: 0, x: -56 });
      gsap.set(content, { opacity: 0, x: 56 });
      ScrollTrigger.create({
        trigger: about,
        start: 'top 78%',
        onEnter: () => {
          gsap.to(imgWrap, { opacity: 1, x: 0, duration: 0.85, ease: 'power2.out' });
          gsap.to(content, { opacity: 1, x: 0, duration: 0.85, ease: 'power2.out' });
        },
        once: true,
      });
    }
  </script>
  <script>
    function initCountUp() {
      const section = document.querySelector('.about-artist');
      if (!section) return;
      const nums = section.querySelectorAll('.about-artist__stat-num');
      if (!nums.length) return;
      const duration = 1500;
      const easeOutQuart = (t) => 1 - Math.pow(1 - t, 4);
      let didRun = false;
      const runCountUp = () => {
        if (didRun) return;
        didRun = true;
        nums.forEach((el) => {
          const target = Number(el.getAttribute('data-target')) || 0;
          const suffix = el.getAttribute('data-suffix') || '';
          const start = performance.now();
          const step = (now) => {
            const elapsed = now - start;
            const p = Math.min(elapsed / duration, 1);
            const value = Math.floor(easeOutQuart(p) * target);
            el.textContent = value + suffix;
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        });
      };
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            observer.disconnect();
            runCountUp();
            return;
          }
        }
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
      observer.observe(section);
      // If section is already in view (e.g. short viewport), run after a frame
      requestAnimationFrame(() => {
        const rect = section.getBoundingClientRect();
        const inView = rect.top < window.innerHeight && rect.bottom > 0;
        if (inView) runCountUp();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCountUp);
    } else {
      initCountUp();
    }
  </script>
</Layout>
