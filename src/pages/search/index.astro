---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Brain Search" description="Private second brain search">
  <section class="brain-search">
    <div class="brain-search__inner">
      <header class="brain-search__header">
        <p class="brain-search__label">Second Brain</p>
        <h1 class="brain-search__title">Search the vault</h1>
        <p class="brain-search__sub">Full-text search across all notes, wiki entries, and resources.</p>
      </header>

      <div id="search"></div>
    </div>
  </section>

  <!-- Pagefind UI assets are generated into dist/_pagefind at build time -->
  <link rel="stylesheet" href={`${base}_pagefind/pagefind-ui.css`} />

  <script is:inline>
    // Pagefind UI is loaded after the page is ready.
    // In dev mode (no _pagefind dir), the search box won't appear — that's expected.
    window.addEventListener('DOMContentLoaded', () => {
      const script = document.createElement('script');
      script.src = '/_pagefind/pagefind-ui.js';
      script.onload = () => {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          excerptLength: 20,
          resetStyles: false,
        });
      };
      document.body.appendChild(script);
    });
  </script>

  <style>
    .brain-search {
      min-height: calc(100vh - 80px);
      padding: calc(var(--space) * 3) calc(var(--space) * 2);
    }

    .brain-search__inner {
      max-width: 760px;
      margin: 0 auto;
    }

    .brain-search__header {
      margin-bottom: calc(var(--space) * 2.5);
    }

    .brain-search__label {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 0.5rem;
    }

    .brain-search__title {
      font-size: 2rem;
      font-weight: 700;
      margin: 0 0 0.75rem;
      background: var(--gradient-primary);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .brain-search__sub {
      color: var(--text-muted);
      margin: 0;
      font-size: 0.95rem;
    }

    /* ── Pagefind UI theming to match the dark-purple palette ── */
    #search {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: #a78bfa;
      --pagefind-ui-text: #f3eef9;
      --pagefind-ui-background: #16101f;
      --pagefind-ui-border: rgba(139, 92, 246, 0.25);
      --pagefind-ui-tag: #16101f;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 12px;
      --pagefind-ui-image-border-radius: 8px;
      --pagefind-ui-font: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* Input field */
    #search :global(.pagefind-ui__search-input) {
      background: var(--bg-elevated);
      color: var(--text);
      border-color: var(--border);
      transition: border-color 0.2s;
    }

    #search :global(.pagefind-ui__search-input:focus) {
      border-color: var(--border-strong);
      outline: none;
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.15);
    }

    /* Result cards */
    #search :global(.pagefind-ui__result) {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: var(--space);
      margin-bottom: 0.75rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    #search :global(.pagefind-ui__result:hover) {
      border-color: var(--border-strong);
      box-shadow: var(--shadow-glow);
    }

    #search :global(.pagefind-ui__result-title a) {
      color: var(--accent-bright);
      text-decoration: none;
      font-weight: 600;
    }

    #search :global(.pagefind-ui__result-excerpt) {
      color: var(--text-muted);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    #search :global(mark) {
      background: rgba(167, 139, 250, 0.25);
      color: var(--accent-bright);
      border-radius: 2px;
      padding: 0 2px;
    }

    /* Clear button */
    #search :global(.pagefind-ui__search-clear) {
      color: var(--text-muted);
    }
  </style>
</Layout>
