---
import Layout from '../../layouts/Layout.astro';
import ArtCard from '../../components/ArtCard.astro';
import { getAllArtworks } from '../../data/artworks';

const artworks = await getAllArtworks();
---
<Layout title="Gallery" description="Full gallery of AI-generated art.">
  <h1 class="page-title">Gallery</h1>
  <p class="page-subtitle">{artworks.length} pieces</p>

  <ul class="gallery-grid">
    {artworks.map((artwork) => (
      <ArtCard artwork={artwork} base={import.meta.env.BASE_URL} />
    ))}
  </ul>
</Layout>
