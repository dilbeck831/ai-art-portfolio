---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Lab" description="Browser tools and experiments. TØX!Q / TOXIQMYND.">
  <section class="lab-soon">
    <div class="lab-soon__bg" aria-hidden="true">
      <div class="lab-soon__orb lab-soon__orb--a"></div>
      <div class="lab-soon__orb lab-soon__orb--b"></div>
      <div class="lab-soon__grid"></div>
    </div>

    <div class="lab-soon__frame">
      <p class="lab-soon__eyebrow">The Lab</p>
      <h1 class="lab-soon__title">Coming soon</h1>
      <p class="lab-soon__subtitle">
        Browser tools for sound, motion, and weird little experiments.
      </p>

      <div class="lab-soon__chips" aria-label="Planned tools">
        <span class="lab-soon__chip">Web Audio</span>
        <span class="lab-soon__chip">3D</span>
        <span class="lab-soon__chip">Prompt tooling</span>
        <span class="lab-soon__chip">AI APIs</span>
      </div>

      <div class="lab-soon__actions">
        <a class="lab-soon__btn lab-soon__btn--primary" href="mailto:toxiqmynd@gmail.com?subject=Lab%20waitlist">
          Join the waitlist
        </a>
        <a class="lab-soon__btn" href={`${import.meta.env.BASE_URL}`}>
          Back to home
        </a>
      </div>

      <p class="lab-soon__note">
        Want a specific tool? Email an idea — I’ll build the best ones first.
      </p>
    </div>
  </section>
</Layout>

<style>
  .lab-soon {
    position: relative;
    min-height: clamp(520px, 70vh, 720px);
    display: grid;
    place-items: center;
    padding: calc(var(--space) * 3) 0;
    overflow: hidden;
  }

  .lab-soon__bg {
    position: absolute;
    inset: -20%;
    pointer-events: none;
    filter: saturate(1.15);
  }

  .lab-soon__grid {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 20%, rgba(139, 92, 246, 0.18), transparent 55%),
      radial-gradient(circle at 30% 70%, rgba(236, 72, 153, 0.14), transparent 52%),
      radial-gradient(circle at 80% 70%, rgba(59, 130, 246, 0.12), transparent 50%),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.02), transparent 40%, rgba(0, 0, 0, 0.15));
  }

  .lab-soon__grid::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(circle at 50% 45%, rgba(0,0,0,0.95), transparent 70%);
    opacity: 0.25;
    transform: perspective(900px) rotateX(55deg) translateY(8%);
    transform-origin: center;
  }

  .lab-soon__orb {
    position: absolute;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(139, 92, 246, 0.35), rgba(139, 92, 246, 0.08) 55%, transparent 72%);
    filter: blur(2px);
    opacity: 0.9;
    animation: labFloat 9s ease-in-out infinite;
  }
  .lab-soon__orb--a {
    left: 10%;
    top: 8%;
  }
  .lab-soon__orb--b {
    right: 8%;
    bottom: 10%;
    width: 460px;
    height: 460px;
    background: radial-gradient(circle at 40% 35%, rgba(236, 72, 153, 0.28), rgba(236, 72, 153, 0.08) 55%, transparent 72%);
    animation-duration: 11s;
    animation-delay: -2s;
  }

  @keyframes labFloat {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -18px, 0); }
  }

  .lab-soon__frame {
    position: relative;
    width: min(880px, 92vw);
    border-radius: 22px;
    padding: clamp(1.25rem, 3.2vw, 2.25rem);
    background: rgba(15, 15, 20, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.10);
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(139, 92, 246, 0.12) inset;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    overflow: hidden;
  }

  .lab-soon__frame::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: conic-gradient(
      from 180deg,
      rgba(139, 92, 246, 0.0),
      rgba(139, 92, 246, 0.55),
      rgba(236, 72, 153, 0.5),
      rgba(59, 130, 246, 0.45),
      rgba(139, 92, 246, 0.0)
    );
    filter: blur(14px);
    opacity: 0.25;
    pointer-events: none;
  }

  .lab-soon__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem 0;
  }

  .lab-soon__title {
    margin: 0;
    font-size: clamp(2.05rem, 5vw, 3.25rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .lab-soon__subtitle {
    margin: 0.85rem 0 0 0;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 56ch;
    color: var(--text-muted);
  }

  .lab-soon__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: calc(var(--space) * 2);
  }

  .lab-soon__chip {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.82);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
  }

  .lab-soon__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: calc(var(--space) * 2);
  }

  .lab-soon__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.18s var(--ease-out), border-color 0.18s var(--ease-out), background 0.18s var(--ease-out);
  }

  .lab-soon__btn:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.09);
  }

  .lab-soon__btn--primary {
    border-color: rgba(139, 92, 246, 0.55);
    background: rgba(139, 92, 246, 0.18);
  }

  .lab-soon__btn--primary:hover {
    border-color: rgba(139, 92, 246, 0.85);
    background: rgba(139, 92, 246, 0.24);
  }

  .lab-soon__note {
    margin: calc(var(--space) * 2) 0 0 0;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .lab-soon__orb { animation: none; }
    .lab-soon__btn { transition: none; }
  }
</style>
