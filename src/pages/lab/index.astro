---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const supabaseUrl = 'https://sbbmducevhpirnthzvtz.supabase.co';
const supabaseKey = 'sb_publishable_X1bha7SOQmNtwVvC4Rhp-Q_67c3guiX';
---
<Layout title="Lab" description="Browser tools and experiments. TØX!Q / TOXIQMYND.">
  <section class="lab-soon" data-base={base}>
    <div class="lab-soon__frame">
      <p class="lab-soon__eyebrow">The Lab</p>
      <h1 class="lab-soon__title">Coming soon</h1>
      <p class="lab-soon__subtitle">Browser tools for sound, motion, and weird little experiments.</p>
      <div class="lab-soon__chips"><span class="lab-soon__chip">Web Audio</span><span class="lab-soon__chip">3D</span><span class="lab-soon__chip">Prompt tooling</span><span class="lab-soon__chip">AI APIs</span></div>
    </div>
  </section>

  <section class="lab-artifacts" id="lab-artifacts">
    <h2 class="section-title">Claude Artifacts</h2>
    <p class="lab-artifacts__sub">Uploaded HTML artifacts appear here automatically.</p>
    <div class="artifact-cards" id="artifact-cards">
      <div class="loading-state">loading…</div>
    </div>
  </section>
</Layout>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" is:inline></script>
<script is:inline>
  (function () {
    var cardsEl = document.getElementById('artifact-cards');
    if (!cardsEl) return;
    var sb = supabase.createClient('https://sbbmducevhpirnthzvtz.supabase.co', 'sb_publishable_X1bha7SOQmNtwVvC4Rhp-Q_67c3guiX');

    async function openArtifact(url) {
      if (!url) return;
      var popup = window.open('', '_blank');
      if (!popup) {
        window.location.href = url;
        return;
      }
      try {
        var resp = await fetch(url, { method: 'GET' });
        if (!resp.ok) throw new Error('Artifact fetch failed');
        var html = await resp.text();
        if (!html) throw new Error('Artifact HTML empty');
        var blobUrl = URL.createObjectURL(new Blob([html], { type: 'text/html;charset=utf-8' }));
        popup.location.replace(blobUrl);
        try { popup.opener = null; } catch (e) {}
      } catch (e) {
        popup.location.replace(url);
      }
    }

    function renderCards(data) {
      if (!data || !data.length) { cardsEl.innerHTML = '<div class="empty-state">No artifacts published yet.</div>'; return; }
      cardsEl.innerHTML = '';
      data.forEach(function (a) {
        var card = document.createElement('article');
        card.className = 'artifact-card';
        var tag = (a.collection || 'ART').toUpperCase().slice(0, 3);
        card.innerHTML = '<h3>' + (a.title || 'Untitled artifact') + '</h3>' +
          '<p class="artifact-card__tag">' + tag + '</p>' +
          '<p class="artifact-card__meta">' + (a.collection || 'claude-html') + '</p>' +
          '<button type="button" class="artifact-card__open" data-open-artifact>Open</button>';
        var openBtn = card.querySelector('[data-open-artifact]');
        if (openBtn) {
          openBtn.addEventListener('click', function () {
            openArtifact(a.artifact_url);
          });
        }
        cardsEl.appendChild(card);
      });
    }

    sb.from('artifacts').select('id,title,collection,artifact_url,created_at').order('created_at', { ascending: false }).limit(60)
      .then(function (r) {
        if (r.error) { cardsEl.innerHTML = '<div class="empty-state">Could not load artifacts.</div>'; return; }
        renderCards(r.data || []);
      })
      .catch(function () { cardsEl.innerHTML = '<div class="empty-state">Could not load artifacts.</div>'; });
  })();
</script>

<style>
  .lab-soon { padding: calc(var(--space) * 2) 0; }
  .lab-soon__frame { border: 1px solid var(--border); border-radius: 18px; padding: 1.25rem; background: var(--surface); }
  .lab-soon__eyebrow { margin: 0; font-size: .7rem; letter-spacing: .2em; text-transform: uppercase; color: var(--accent); }
  .lab-soon__title { margin: .4rem 0; font-size: clamp(2rem, 5vw, 3rem); background: var(--gradient-primary); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .lab-soon__subtitle { margin: 0; color: var(--text-muted); }
  .lab-soon__chips { margin-top: 1rem; display: flex; gap: .5rem; flex-wrap: wrap; }
  .lab-soon__chip { border: 1px solid var(--border); border-radius: 999px; padding: .3rem .6rem; font-size: .8rem; color: var(--text-muted); }

  .lab-artifacts { margin-top: calc(var(--space) * 3); }
  .lab-artifacts__sub { color: var(--text-muted); margin: 0 0 var(--space) 0; }
  .artifact-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space); }
  :global(.artifact-card) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: calc(var(--space) * 1.25);
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-out), border-color 0.3s;
  }
  :global(.artifact-card:hover) {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--border-strong);
  }
  :global(.artifact-card__tag) {
    margin: 0 0 0.5rem 0;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--purple-500);
  }
  :global(.artifact-card h3) {
    margin: 0 0 .45rem 0;
    font-size: .98rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
  }
  :global(.artifact-card__meta) {
    margin: 0 0 1rem 0;
    color: var(--text-muted);
    font-size: .8rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    line-height: 1.45;
  }
  :global(.artifact-card__open) {
    border: 1px solid var(--accent);
    background: transparent;
    color: var(--accent);
    border-radius: 999px;
    padding: .45rem .9rem;
    font-size: .82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color .25s var(--ease-out), transform .25s var(--ease-spring), filter .25s var(--ease-out);
  }
  :global(.artifact-card__open:hover) {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  @media (max-width: 768px) {
    .artifact-cards { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .artifact-cards { grid-template-columns: 1fr; }
  }
</style>
