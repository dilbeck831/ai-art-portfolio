---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Get in touch.">
  <h1 class="page-title">Contact</h1>
  <div class="prose">
    <p>
      For commissions, collaborations, or just to say hi, reach out via your preferred channel.
      Replace this with your email, contact form, or social links.
    </p>
    <p>
      Edit <code>src/pages/contact.astro</code> to add a mailto link, form, or embed.
    </p>
  </div>
</Layout>
