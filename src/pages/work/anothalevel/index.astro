---
import WorkLayout from '../../../layouts/WorkLayout.astro';
import { readdirSync } from 'node:fs';
import { existsSync } from 'node:fs';
import { extname, resolve } from 'node:path';

const base = import.meta.env.BASE_URL;
const artDir = resolve(process.cwd(), 'public', 'art', 'anothalevel');
const imageExt = new Set(['.jpg', '.jpeg', '.png', '.webp', '.gif', '.avif']);

const dirExists = existsSync(artDir);
const files = dirExists
  ? readdirSync(artDir, { withFileTypes: true })
      .filter((entry) => entry.isFile())
      .map((entry) => entry.name)
      .filter((name) => imageExt.has(extname(name).toLowerCase()))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }))
  : [];

const artworks = files.map((name) => ({
  src: `${base}art/anothalevel/${encodeURIComponent(name)}`,
  title: name.replace(/\.[^.]+$/, ''),
}));
const artworksJson = JSON.stringify(artworks).replace(/</g, '\\u003c');
---
<WorkLayout
  title="Anotha Level"
  description="Pinterest-style mosaic gallery and lightbox. TØX!Q / TOXIQMYND."
  breadcrumb={[{ label: 'Anotha Level', href: `${import.meta.env.BASE_URL}work/anothalevel/` }]}
>
  <h1 class="page-title">Anotha Level</h1>
  <p class="page-subtitle">A mosaic feed with full-screen lightbox viewing.</p>

  <section
    class="mosaic-gallery"
    id="mosaic-gallery"
    aria-label="Anotha Level artwork mosaic"
  >
    {artworks.length > 0 ? (
      <div id="mosaic-grid" class="mosaic-gallery__grid" aria-live="polite">
        {artworks.map((art, i) => (
          <button type="button" class="mosaic-tile" data-index={i} aria-label={art.title}>
            <img src={art.src} alt={art.title} loading={i < 8 ? 'eager' : 'lazy'} decoding="async" />
          </button>
        ))}
      </div>
    ) : (
      <p class="mosaic-gallery__state">No images found in `public/art/anothalevel`.</p>
    )}
  </section>

  <div id="mosaic-lightbox" class="mosaic-lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox" hidden>
    <div class="mosaic-lightbox__backdrop" id="mosaic-lightbox-backdrop"></div>
    <button type="button" class="mosaic-lightbox__close" id="mosaic-lightbox-close" aria-label="Close">×</button>
    <button type="button" class="mosaic-lightbox__nav mosaic-lightbox__nav--prev" id="mosaic-lightbox-prev" aria-label="Previous image">‹</button>
    <div class="mosaic-lightbox__content">
      <img id="mosaic-lightbox-img" src="" alt="" />
      <p class="mosaic-lightbox__counter" id="mosaic-lightbox-counter" aria-live="polite"></p>
    </div>
    <button type="button" class="mosaic-lightbox__nav mosaic-lightbox__nav--next" id="mosaic-lightbox-next" aria-label="Next image">›</button>
  </div>
  <script id="anotha-artworks-json" type="application/json" set:html={artworksJson}></script>
  <script is:inline>
    (function () {
      var gridEl = document.getElementById('mosaic-grid');
      var artworks = [];
      try {
        var jsonEl = document.getElementById('anotha-artworks-json');
        var rawJson = jsonEl ? (jsonEl.textContent || '[]') : '[]';
        artworks = JSON.parse(rawJson);
      } catch (e) {
        artworks = [];
      }
      var lightbox = document.getElementById('mosaic-lightbox');
      var lbImg = document.getElementById('mosaic-lightbox-img');
      var lbCounter = document.getElementById('mosaic-lightbox-counter');
      var lbPrev = document.getElementById('mosaic-lightbox-prev');
      var lbNext = document.getElementById('mosaic-lightbox-next');
      var lbClose = document.getElementById('mosaic-lightbox-close');
      var lbBackdrop = document.getElementById('mosaic-lightbox-backdrop');

      if (!gridEl || !lightbox || !lbImg) return;
      var lightboxIndex = 0;

      function updateLightbox() {
        if (!artworks.length) return;
        var item = artworks[lightboxIndex] || {};
        lbImg.src = item.src || '';
        lbImg.alt = item.title || 'Artwork';
        if (lbCounter) lbCounter.textContent = (lightboxIndex + 1) + ' / ' + artworks.length;
        if (lbPrev) lbPrev.style.visibility = artworks.length <= 1 ? 'hidden' : 'visible';
        if (lbNext) lbNext.style.visibility = artworks.length <= 1 ? 'hidden' : 'visible';
      }

      function onLightboxKeydown(e) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') {
          lightboxIndex = (lightboxIndex - 1 + artworks.length) % artworks.length;
          updateLightbox();
        }
        if (e.key === 'ArrowRight') {
          lightboxIndex = (lightboxIndex + 1) % artworks.length;
          updateLightbox();
        }
      }

      function openLightbox(index) {
        lightboxIndex = index;
        updateLightbox();
        lightbox.hidden = false;
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', onLightboxKeydown);
      }

      function closeLightbox() {
        lightbox.hidden = true;
        document.body.style.overflow = '';
        if (lbImg) lbImg.src = '';
        document.removeEventListener('keydown', onLightboxKeydown);
      }

      if (lbClose) lbClose.addEventListener('click', closeLightbox);
      if (lbBackdrop) lbBackdrop.addEventListener('click', closeLightbox);
      if (lbPrev) lbPrev.addEventListener('click', function () {
        lightboxIndex = (lightboxIndex - 1 + artworks.length) % artworks.length;
        updateLightbox();
      });
      if (lbNext) lbNext.addEventListener('click', function () {
        lightboxIndex = (lightboxIndex + 1) % artworks.length;
        updateLightbox();
      });

      var tiles = gridEl.querySelectorAll('.mosaic-tile');
      tiles.forEach(function (tile) {
        tile.addEventListener('click', function () {
          var idx = parseInt(tile.getAttribute('data-index') || '0', 10);
          openLightbox(idx);
        });
      });
    })();
  </script>
</WorkLayout>

<style>
  .mosaic-gallery {
    margin-top: calc(var(--space) * 2);
  }

  .mosaic-gallery__loading {
    color: var(--text-muted);
    text-align: center;
    padding: calc(var(--space) * 2) 0;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
  }

  .mosaic-gallery__state {
    color: var(--text-muted);
    text-align: center;
    padding: calc(var(--space) * 2) 0;
    font-size: 0.9rem;
  }

  .mosaic-gallery__state--error {
    color: var(--color-error, #f87171);
  }

  .mosaic-gallery__grid {
    column-count: 4;
    column-gap: 8px;
  }

  :global(.mosaic-tile) {
    display: block;
    width: 100%;
    break-inside: avoid;
    margin-bottom: 8px;
    border: 1px solid transparent;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-elevated);
    padding: 0;
    cursor: pointer;
    position: relative;
    transition: border-color 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out), transform 0.3s var(--ease-spring);
  }

  :global(.mosaic-tile:hover) {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    z-index: 2;
  }

  :global(.mosaic-tile img) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 1100px) {
    .mosaic-gallery__grid { column-count: 3; }
  }
  @media (max-width: 760px) {
    .mosaic-gallery__grid { column-count: 2; }
  }
  @media (max-width: 420px) {
    .mosaic-gallery__grid { column-count: 2; column-gap: 6px; }
    :global(.mosaic-tile) { margin-bottom: 6px; }
  }

  .mosaic-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .mosaic-lightbox[hidden] {
    display: none !important;
  }

  .mosaic-lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    cursor: pointer;
  }

  .mosaic-lightbox__content {
    position: relative;
    z-index: 2;
    max-width: 92vw;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .mosaic-lightbox__content img {
    max-width: 100%;
    max-height: 84vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.6);
  }

  .mosaic-lightbox__counter {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
  }

  .mosaic-lightbox__close,
  .mosaic-lightbox__nav {
    position: absolute;
    z-index: 3;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }

  .mosaic-lightbox__close {
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    font-size: 1.75rem;
    line-height: 1;
  }

  .mosaic-lightbox__nav {
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    font-size: 2rem;
    line-height: 1;
  }

  .mosaic-lightbox__close:hover,
  .mosaic-lightbox__nav:hover {
    background: rgba(139, 92, 246, 0.35);
    border-color: var(--border-strong);
  }

  .mosaic-lightbox__nav--prev { left: 1rem; }
  .mosaic-lightbox__nav--next { right: 1rem; }

  @media (max-width: 600px) {
    .mosaic-lightbox__nav { display: none; }
  }
</style>
