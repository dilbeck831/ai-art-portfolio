---
import WorkLayout from '../../../layouts/WorkLayout.astro';
import ArtGallery from '../../../components/work/ArtGallery.astro';
import ProcessBlock from '../../../components/work/ProcessBlock.astro';
import { getArtworksBySeries } from '../../../data/artworks';
import { processSections } from '../../../data/ai-art-process';
import { siteTitle } from '../../../data/meta';
const base = import.meta.env.BASE_URL;
const fragmentPieces = await getArtworksBySeries('fragment');
---
<WorkLayout
  title="AI Art"
  description="Fragment series and generative AI art. TØX!Q / TOXIQMYND."
  breadcrumb={[{ label: 'AI Art', href: `${base}work/ai-art/` }]}
>
  <h1 class="page-title">AI Art</h1>
  <p class="page-subtitle">Fragment series and process. Baroque detail, animation, style profiles.</p>
  <ArtGallery artworks={fragmentPieces} base={base} />
  <section class="process-section">
    <h2 class="section-title">Process</h2>
    <ProcessBlock sections={processSections} />
  </section>
</WorkLayout>

<style>
  .process-section {
    margin-top: calc(var(--space) * 3);
  }
</style>
