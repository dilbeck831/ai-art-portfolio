---
import WorkLayout from '../../../layouts/WorkLayout.astro';
import { artworks, getArtworkBySlug } from '../../../data/artworks';
import { brandName } from '../../../data/meta';

export async function getStaticPaths() {
  return artworks.map((artwork) => ({
    params: { slug: artwork.slug },
    props: { artwork },
  }));
}

const { artwork } = Astro.props;
const base = import.meta.env.BASE_URL;

// Prev / next within same series
const seriesArtworks = artworks.filter((a) => a.series === artwork.series);
const idx = seriesArtworks.findIndex((a) => a.slug === artwork.slug);
const prev = seriesArtworks[idx - 1];
const next = seriesArtworks[idx + 1];

const imageUrl = `${base}art/${artwork.image}`;
---

<WorkLayout
  title={artwork.title}
  description={`${artwork.title} — ${artwork.series} series. ${brandName}.`}
  breadcrumb={[
    { label: 'AI Art', href: `${base}work/ai-art/` },
    { label: artwork.title, href: `${base}work/ai-art/${artwork.slug}/` },
  ]}
>
  <article class="artwork-detail">

    <div class="artwork-detail__media">
      {artwork.video ? (
        <video
          src={`${base}art/${artwork.video}`}
          poster={imageUrl}
          controls
          playsinline
          class="artwork-detail__image"
        />
      ) : (
        <img
          src={imageUrl}
          alt={artwork.title}
          class="artwork-detail__image"
          loading="eager"
          decoding="async"
        />
      )}
    </div>

    <div class="artwork-detail__body">
      <p class="artwork-detail__series">{artwork.series}</p>
      <h1 class="artwork-detail__title">{artwork.title}</h1>
      {artwork.year && <p class="artwork-detail__year">{artwork.year}</p>}
      {artwork.description && (
        <p class="artwork-detail__description">{artwork.description}</p>
      )}
    </div>

    <nav class="artwork-detail__nav" aria-label="Artwork navigation">
      {prev ? (
        <a href={`${base}work/ai-art/${prev.slug}/`} class="artwork-detail__nav-link artwork-detail__nav-link--prev">
          <span class="artwork-detail__nav-dir">← Previous</span>
          <span class="artwork-detail__nav-name">{prev.title}</span>
        </a>
      ) : <span />}
      <a href={`${base}work/ai-art/`} class="artwork-detail__nav-link artwork-detail__nav-link--all">
        All Works
      </a>
      {next ? (
        <a href={`${base}work/ai-art/${next.slug}/`} class="artwork-detail__nav-link artwork-detail__nav-link--next">
          <span class="artwork-detail__nav-dir">Next →</span>
          <span class="artwork-detail__nav-name">{next.title}</span>
        </a>
      ) : <span />}
    </nav>

  </article>
</WorkLayout>

<style>
  .artwork-detail {
    max-width: 960px;
    margin: 0 auto;
  }

  .artwork-detail__media {
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-elevated);
    margin-bottom: calc(var(--space) * 2);
  }

  .artwork-detail__image {
    width: 100%;
    height: auto;
    display: block;
    max-height: 85vh;
    object-fit: contain;
  }

  .artwork-detail__body {
    max-width: 640px;
    margin-bottom: calc(var(--space) * 3);
  }

  .artwork-detail__series {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }

  .artwork-detail__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1.1;
  }

  .artwork-detail__year {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .artwork-detail__description {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  /* Prev / Next nav */
  .artwork-detail__nav {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding-top: calc(var(--space) * 2);
    border-top: 1px solid var(--border);
    gap: var(--space);
  }

  .artwork-detail__nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.2s var(--ease-out);
    max-width: 220px;
  }

  .artwork-detail__nav-link:hover {
    color: var(--accent-bright);
  }

  .artwork-detail__nav-link--all {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    align-self: center;
  }

  .artwork-detail__nav-link--next {
    align-items: flex-end;
    text-align: right;
  }

  .artwork-detail__nav-dir {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .artwork-detail__nav-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: inherit;
  }
</style>
