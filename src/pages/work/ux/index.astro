---
import WorkLayout from '../../../layouts/WorkLayout.astro';
import CaseStudyCard from '../../../components/work/CaseStudyCard.astro';
import { caseStudies } from '../../../data/case-studies';
import { capabilities } from '../../../data/capabilities';
import { siteTitle } from '../../../data/meta';
const base = import.meta.env.BASE_URL;
const sorted = [...caseStudies].sort((a, b) => a.order - b.order);
---
<WorkLayout title="UI/UX" description="Case studies and capabilities. Enterprise UX, IA, design systems." breadcrumb={[{ label: 'UI/UX', href: `${base}work/ux/` }]}>
  <h1 class="page-title">UI/UX</h1>
  <p class="page-subtitle">Enterprise information architecture, design systems, and product design.</p>
  <section class="case-studies-list">
    <h2 class="section-title">Case studies</h2>
    <ul class="case-studies-grid">
      {sorted.map((study) => (
        <CaseStudyCard study={study} base={base} />
      ))}
    </ul>
  </section>
  <section class="capabilities-section">
    <h2 class="section-title">Capabilities</h2>
    <ul class="capabilities-list">
      {capabilities.map((c) => (
        <li>{c.name}</li>
      ))}
    </ul>
  </section>
</WorkLayout>

<style>
  .case-studies-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .capabilities-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .capabilities-section {
    margin-top: calc(var(--space) * 3);
  }
</style>
