---
import WorkLayout from '../../layouts/WorkLayout.astro';
import TracksSection from '../../components/work/TracksSection.astro';
import ToxUploadsSection from '../../components/work/ToxUploadsSection.astro';
import ProcessBlock from '../../components/work/ProcessBlock.astro';
import { sunoTracks } from '../../data/music';
import { processSections } from '../../data/ai-art-process';
const sunoEmbedBase = 'https://suno.com/embed';
---
<WorkLayout title="Work" description="AI Art, Music, and UI/UX — TØX!Q / TOXIQMYND.">
  <h1 class="page-title">Work</h1>
  <p class="page-subtitle">AI Art, music, and UI/UX. One identity.</p>
  <TracksSection tracks={sunoTracks} embedBase={sunoEmbedBase} />
  <ToxUploadsSection />
  <section class="process-section">
    <h2 class="section-title">Process</h2>
    <ProcessBlock sections={processSections} />
  </section>
</WorkLayout>

<style>
  .process-section {
    margin-top: calc(var(--space) * 3);
  }
</style>
