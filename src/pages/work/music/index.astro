---
import WorkLayout from '../../../layouts/WorkLayout.astro';
import { musicPlaceholder, sunoTracks } from '../../../data/music';
import { siteTitle } from '../../../data/meta';
const base = import.meta.env.BASE_URL;
const sunoEmbedBase = 'https://suno.com/embed';
---
<WorkLayout title="Music" description="Music and production. TØX!Q / TOXIQMYND." breadcrumb={[{ label: 'Music', href: `${base}work/music/` }]}>
  <h1 class="page-title">Music</h1>
  <p class="page-subtitle">Drum and bass, neurofunk, deep house, dubstep.</p>

  {sunoTracks.length > 0 && (
    <section class="suno-embeds" aria-label="Suno tracks" data-suno-embed-base={sunoEmbedBase}>
      <h2 class="suno-embeds__title">Tracks</h2>
      <div class="suno-embeds__player-wrap" aria-live="polite">
        <iframe
          id="suno-embed-iframe"
          src={`${sunoEmbedBase}/${sunoTracks[0].id}`}
          title={`${sunoTracks[0].title} — Suno`}
          class="suno-embeds__iframe"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; fullscreen; gyroscope"
        />
      </div>
      <ul class="suno-embeds__track-list" role="list" aria-label="Select a track to play">
        {sunoTracks.map((track, i) => (
          <li>
            <button
              type="button"
              class={`suno-card ${i === 0 ? 'is-active' : ''}`}
              data-suno-id={track.id}
              data-suno-title={track.title}
            >
              <span class="suno-card__art">
                <img
                  src={`https://cdn2.suno.ai/${track.id}.jpeg`}
                  alt=""
                  width="120"
                  height="120"
                  onerror="this.parentElement?.classList.add('is-fallback')"
                />
              </span>
              <span class="suno-card__info">
                <span class="suno-card__title">{track.title}</span>
                <span class="suno-card__play" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M8 5v14l11-7L8 5z" fill="currentColor"/>
                  </svg>
                </span>
              </span>
            </button>
          </li>
        ))}
      </ul>
      <script>
        (function () {
          const container = document.querySelector('.suno-embeds');
          if (!container) return;
          const iframe = document.getElementById('suno-embed-iframe');
          const base = container.getAttribute('data-suno-embed-base');
          const cards = container.querySelectorAll('.suno-card');
          cards.forEach((btn) => {
            btn.addEventListener('click', () => {
              const id = btn.getAttribute('data-suno-id');
              const title = btn.getAttribute('data-suno-title');
              if (!id || !iframe || !base) return;
              iframe.src = base + '/' + id;
              iframe.title = title + ' — Suno';
              cards.forEach((c) => c.classList.remove('is-active'));
              btn.classList.add('is-active');
            });
          });
        })();
      </script>
    </section>
  )}

  <div class="prose music-placeholder">
    <p>{musicPlaceholder.message}</p>
    <p>Genres: {musicPlaceholder.genres.join(', ')}.</p>
  </div>
</WorkLayout>
