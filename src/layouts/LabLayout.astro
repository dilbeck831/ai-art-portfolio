---
import '../styles/global.css';
import GlowCursor from '../components/GlowCursor.astro';
import Nav from '../components/Nav.astro';
import SocialIcons from '../components/SocialIcons.astro';
import SeoHead from '../components/SeoHead.astro';
import { siteTitle, brandName, defaultDescription } from '../data/meta';

interface Props {
  title: string;
  description?: string;
}
const { title, description = defaultDescription } = Astro.props;
const base = import.meta.env.BASE_URL;
const site = Astro.site;
const ogImageAbsolute = site
  ? new URL(`${base.replace(/^\//, '')}og-image.png`, site).href
  : new URL(`${base}og-image.png`, Astro.url.origin).href;
const canonicalUrl = Astro.url.href;
const fullTitle = `${title} · Lab · ${siteTitle}`;
const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === base ? currentPath === base || currentPath === base.replace(/\/$/, '') : currentPath.startsWith(path);
const navLinks = [
  { href: base, label: 'Home' },
  { href: `${base}work/`, label: 'Work' },
  { href: `${base}lab/`, label: 'Lab' },
  { href: `${base}about/`, label: 'About' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta name="description" content={description} />
    <SeoHead description={description} ogImageAbsolute={ogImageAbsolute} canonicalUrl={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__left">
        <a href={base} class="logo" aria-label={brandName}>
          <img src={`${base}artist.jpeg`} alt="" class="logo__img" width="60" height="60" loading="eager" decoding="async" />
        </a>
        <span class="site-header__sep" aria-hidden="true"></span>
        <Nav currentPath={Astro.url.pathname} />
      </div>
      <div class="site-header__right">
        <span class="site-header__sep" aria-hidden="true"></span>
        <SocialIcons />
      </div>
      <div class="site-header__mobile-menu">
        <button type="button" class="site-header__menu-btn" aria-expanded="false" aria-controls="header-menu-nav" id="header-menu-btn">
          Menu
        </button>
        <nav id="header-menu-nav" class="site-header__menu-nav" aria-label="Main" hidden>
          <ul class="site-header__menu-list">
            {navLinks.map(({ href, label }) => (
              <li><a href={href} class:list={['site-header__menu-link', isActive(href) && 'site-header__menu-link--active']}>{label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p><a href={`${base}lab/`}>Lab</a> · <a href={base}>Home</a> · <a href={`${base}about/`}>About</a> · <a href={`${base}admin/`}>Admin</a> · <a href="mailto:toxiqmynd@gmail.com">Contact</a></p>
    </footer>
    <script>
      const btn = document.getElementById('header-menu-btn');
      const menu = document.getElementById('header-menu-nav');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          menu.hidden = expanded;
        });
      }
    </script>
    <GlowCursor />
  </body>
</html>

<style>
</style>
