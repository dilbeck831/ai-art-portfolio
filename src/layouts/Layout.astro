---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SocialIcons from '../components/SocialIcons.astro';
import { siteTitle, brandName, defaultDescription } from '../data/meta';

interface Props {
  title: string;
  description?: string;
}
const { title, description = defaultDescription } = Astro.props;
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const pathNorm = pathname.replace(/\/$/, '') || '/';
const baseNorm = base.replace(/\/$/, '') || '/';
const currentPath = pathname;
const fullTitle = title === 'Home' ? `${brandName} · ${siteTitle}` : `${title} · ${siteTitle}`;
const isHome = pathNorm === baseNorm;
const isActive = (path: string) => (path === base ? currentPath === base || currentPath === base.replace(/\/$/, '') : currentPath.startsWith(path));
const navLinks = [
  { href: base, label: 'Home' },
  { href: `${base}work/`, label: 'Work' },
  { href: `${base}work/ai-art/`, label: 'AI Art' },
  { href: `${base}work/music/`, label: 'Music' },
  { href: `${base}work/ux/`, label: 'UI/UX' },
  { href: `${base}lab/`, label: 'Lab' },
  { href: `${base}about/`, label: 'About' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://sbbmducevhpirnthzvtz.supabase.co" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preload" href={`${base}artist.jpeg`} as="image" />
    <title>{fullTitle}</title>
  </head>
  <body class:list={[isHome && 'page-home']}>
    <header class="site-header">
      <div class="site-header__left">
        <a href={base} class="logo" aria-label={brandName}>
          <img src={`${base}artist.jpeg`} alt="" class="logo__img" width="60" height="60" loading="eager" decoding="async" />
        </a>
        <span class="site-header__sep" aria-hidden="true"></span>
        <Nav currentPath={Astro.url.pathname} />
      </div>
      <div class="site-header__right">
        <span class="site-header__sep" aria-hidden="true"></span>
        <SocialIcons />
      </div>
      {!isHome && (
        <div class="site-header__mobile-menu">
          <button type="button" class="site-header__menu-btn" aria-expanded="false" aria-controls="header-menu-nav" id="header-menu-btn">
            Menu
          </button>
          <nav id="header-menu-nav" class="site-header__menu-nav" aria-label="Main" hidden>
            <ul class="site-header__menu-list">
              {navLinks.map(({ href, label }) => (
                <li><a href={href} class:list={['site-header__menu-link', isActive(href) && 'site-header__menu-link--active']}>{label}</a></li>
              ))}
            </ul>
          </nav>
        </div>
      )}
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p><a href={base}>Home</a> · <a href={`${base}work/`}>Work</a> · <a href={`${base}lab/`}>Lab</a> · <a href={`${base}about/`}>About</a> · <a href="mailto:toxiqmynd@gmail.com">Contact</a></p>
      <p>© {new Date().getFullYear()} {brandName} / {siteTitle}</p>
    </footer>
    <script>
      import gsap from 'gsap';
      const logo = document.querySelector('.logo');
      const navLinks = document.querySelectorAll('.nav .nav__link');
      const socialLinks = document.querySelectorAll('.social-icons__link');
      if (logo || navLinks.length) {
        gsap.set([logo, ...navLinks, ...socialLinks], { opacity: 0, y: -8 });
        gsap.to([logo, ...navLinks, ...socialLinks], {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.06,
          delay: 0.2,
          ease: 'power2.out',
        });
      }
      const headerMenuBtn = document.getElementById('header-menu-btn');
      const headerMenuNav = document.getElementById('header-menu-nav');
      if (headerMenuBtn && headerMenuNav) {
        headerMenuBtn.addEventListener('click', () => {
          const expanded = headerMenuBtn.getAttribute('aria-expanded') === 'true';
          headerMenuBtn.setAttribute('aria-expanded', String(!expanded));
          headerMenuNav.hidden = expanded;
        });
      }
    </script>
  </body>
</html>
