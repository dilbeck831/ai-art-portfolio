---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SocialIcons from '../components/SocialIcons.astro';
import { siteTitle, brandName, defaultDescription } from '../data/meta';

interface Props {
  title: string;
  description?: string;
}
const { title, description = defaultDescription } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(base, base).replace(/\/$/, base === '/' ? '' : base);
const fullTitle = title === 'Home' ? `${brandName} · ${siteTitle}` : `${title} · ${siteTitle}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__left">
        <a href={base} class="logo">{brandName}</a>
        <span class="site-header__sep" aria-hidden="true"></span>
        <Nav currentPath={Astro.url.pathname} />
      </div>
      <div class="site-header__right">
        <span class="site-header__sep" aria-hidden="true"></span>
        <SocialIcons />
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p><a href={base}>Home</a> · <a href={`${base}work/`}>Work</a> · <a href={`${base}lab/`}>Lab</a> · <a href={`${base}about/`}>About</a> · <a href={`${base}contact/`}>Contact</a></p>
      <p>© {new Date().getFullYear()} {brandName} / {siteTitle}</p>
    </footer>
    <script>
      import gsap from 'gsap';
      const logo = document.querySelector('.logo');
      const navLinks = document.querySelectorAll('.nav .nav__link');
      const socialLinks = document.querySelectorAll('.social-icons__link');
      if (logo || navLinks.length) {
        gsap.set([logo, ...navLinks, ...socialLinks], { opacity: 0, y: -8 });
        gsap.to([logo, ...navLinks, ...socialLinks], {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.06,
          delay: 0.2,
          ease: 'power2.out',
        });
      }
    </script>
  </body>
</html>
