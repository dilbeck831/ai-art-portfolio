---
import type { Artwork } from '../data/artworks';

interface Props {
  artworks: Artwork[];
  base?: string;
}

const { artworks, base = import.meta.env.BASE_URL } = Astro.props;

// Slot 0 = hero (large left), slots 1-4 = 2x2 grid, slots 5-6 = bottom row
const hero   = artworks[0];
const grid   = artworks.slice(1, 5);
const bottom = artworks.slice(5, 7);
---

{artworks.length > 0 && (
  <section class="featured-collection" id="featured">

    <div class="featured-collection__header">
      <p class="featured-collection__eyebrow">Selected Works</p>
      <h2 class="featured-collection__heading">Featured Collection</h2>
    </div>

    <div class="featured-collection__top">

      {/* Hero — large left cell */}
      {hero && (
        <a
          href={`${base}work/ai-art/${hero.slug}/`}
          class="featured-cell featured-cell--hero"
          aria-label={hero.title}
        >
          <img
            src={`${base}art/${hero.image}`}
            alt={hero.title}
            loading="eager"
            decoding="async"
          />
          <div class="featured-cell__overlay">
            <span class="featured-cell__title">{hero.title}</span>
            <span class="featured-cell__cat">Fine Art</span>
          </div>
        </a>
      )}

      {/* 2×2 grid — right side */}
      <div class="featured-collection__grid2x2">
        {grid.map((artwork) => (
          <a
            href={`${base}work/ai-art/${artwork.slug}/`}
            class="featured-cell featured-cell--sm"
            aria-label={artwork.title}
          >
            <img
              src={`${base}art/${artwork.image}`}
              alt={artwork.title}
              loading="lazy"
              decoding="async"
            />
            <div class="featured-cell__overlay">
              <span class="featured-cell__title">{artwork.title}</span>
              <span class="featured-cell__cat">Fine Art</span>
            </div>
          </a>
        ))}
      </div>

    </div>

    {bottom.length > 0 && (
      <div class="featured-collection__bottom">
        {bottom.map((artwork) => (
          <a
            href={`${base}work/ai-art/${artwork.slug}/`}
            class="featured-cell featured-cell--tall"
            aria-label={artwork.title}
          >
            <img
              src={`${base}art/${artwork.image}`}
              alt={artwork.title}
              loading="lazy"
              decoding="async"
            />
            <div class="featured-cell__overlay">
              <span class="featured-cell__title">{artwork.title}</span>
              <span class="featured-cell__cat">Fine Art</span>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="featured-collection__cta">
      <a href={`${base}work/ai-art/`} class="featured-collection__cta-link">
        View All Works →
      </a>
    </div>

  </section>
)}

<style>
  .featured-collection {
    padding: var(--fc-pad, 5rem) 0 4rem;
    position: relative;
  }

  /* ── Header ── */
  .featured-collection__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .featured-collection__eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }

  .featured-collection__heading {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
  }

  /* ── Top row: hero + 2×2 ── */
  .featured-collection__top {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 6px;
    margin-bottom: 6px;
  }

  .featured-collection__grid2x2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 6px;
  }

  /* ── Bottom row: 2 tall cells ── */
  .featured-collection__bottom {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }

  /* ── Shared cell styles ── */
  .featured-cell {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: 3px;
    text-decoration: none;
    background: var(--bg-elevated);
  }

  .featured-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.65s var(--ease-out);
  }

  .featured-cell:hover img {
    transform: scale(1.05);
  }

  /* Hero tall */
  .featured-cell--hero {
    min-height: 540px;
  }

  /* 2×2 cells */
  .featured-cell--sm {
    aspect-ratio: auto;
  }

  /* Bottom tall cells */
  .featured-cell--tall {
    aspect-ratio: 3 / 4;
  }

  /* ── Hover overlay ── */
  .featured-cell__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.25rem 1.1rem;
    background: linear-gradient(to top, rgba(10, 6, 18, 0.82) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 3px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s var(--ease-out),
      transform 0.3s var(--ease-out);
  }

  .featured-cell:hover .featured-cell__overlay {
    opacity: 1;
    transform: translateY(0);
  }

  /* Also show overlay on focus (keyboard nav) */
  .featured-cell:focus-visible .featured-cell__overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-cell:focus-visible {
    outline: 2px solid var(--purple-500);
    outline-offset: 3px;
  }

  .featured-cell__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.01em;
  }

  .featured-cell__cat {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ── CTA ── */
  .featured-collection__cta {
    text-align: center;
    margin-top: 2.25rem;
  }

  .featured-collection__cta-link {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 3px;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out);
  }

  .featured-collection__cta-link:hover {
    color: var(--accent-bright);
    border-color: var(--border-strong);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .featured-collection__top {
      grid-template-columns: 1fr;
    }

    .featured-cell--hero {
      min-height: 420px;
    }

    .featured-collection__bottom {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .featured-collection__grid2x2 {
      grid-template-columns: 1fr 1fr;
    }

    .featured-collection__bottom {
      grid-template-columns: 1fr;
    }

    .featured-cell--tall {
      aspect-ratio: 4 / 3;
    }
  }
</style>
