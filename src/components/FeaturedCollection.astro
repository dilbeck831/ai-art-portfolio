---
import type { Artwork } from '../data/artworks';

interface Props {
  artworks: Artwork[];
  base?: string;
}

const { artworks, base = import.meta.env.BASE_URL } = Astro.props;

// Slot 0 = hero (large left), slots 1-4 = 2x2 grid, slots 5-6 = bottom row
const hero   = artworks[0];
const grid   = artworks.slice(1, 5);
const bottom = artworks.slice(5, 7);
---

{artworks.length > 0 && (
  <section class="featured-collection" id="featured">

    <div class="featured-collection__header">
      <p class="featured-collection__eyebrow">Selected Works</p>
      <h2 class="featured-collection__heading">Featured Collection</h2>
    </div>

    <div class="featured-collection__top">

      {/* Hero — large left cell */}
      {hero && (
        <a
          href={`${base}work/ai-art/${hero.slug}/`}
          class="featured-cell featured-cell--hero"
          aria-label={hero.title}
        >
          <img
            src={`${base}art/${hero.image}`}
            alt={hero.title}
            loading="eager"
            decoding="async"
          />
          <div class="featured-cell__overlay">
            <span class="featured-cell__title">{hero.title}</span>
            <span class="featured-cell__cat">Fine Art</span>
          </div>
        </a>
      )}

      {/* 2×2 grid — right side */}
      <div class="featured-collection__grid2x2">
        {grid.map((artwork) => (
          <a
            href={`${base}work/ai-art/${artwork.slug}/`}
            class="featured-cell featured-cell--sm"
            aria-label={artwork.title}
          >
            <img
              src={`${base}art/${artwork.image}`}
              alt={artwork.title}
              loading="lazy"
              decoding="async"
            />
            <div class="featured-cell__overlay">
              <span class="featured-cell__title">{artwork.title}</span>
              <span class="featured-cell__cat">Fine Art</span>
            </div>
          </a>
        ))}
      </div>

    </div>

    {bottom.length > 0 && (
      <div class="featured-collection__bottom">
        {bottom.map((artwork) => (
          <a
            href={`${base}work/ai-art/${artwork.slug}/`}
            class="featured-cell featured-cell--tall"
            aria-label={artwork.title}
          >
            <img
              src={`${base}art/${artwork.image}`}
              alt={artwork.title}
              loading="lazy"
              decoding="async"
            />
            <div class="featured-cell__overlay">
              <span class="featured-cell__title">{artwork.title}</span>
              <span class="featured-cell__cat">Fine Art</span>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="featured-collection__cta">
      <a href={`${base}work/ai-art/`} class="featured-collection__cta-link">
        View All Works →
      </a>
    </div>

    <div id="featured-lightbox" class="featured-lightbox" role="dialog" aria-modal="true" aria-label="Featured image lightbox" hidden>
      <div class="featured-lightbox__backdrop" id="featured-lightbox-backdrop"></div>
      <button type="button" class="featured-lightbox__close" id="featured-lightbox-close" aria-label="Close">×</button>
      <button type="button" class="featured-lightbox__nav featured-lightbox__nav--prev" id="featured-lightbox-prev" aria-label="Previous image">‹</button>
      <div class="featured-lightbox__content">
        <img id="featured-lightbox-img" src="" alt="" />
        <p class="featured-lightbox__caption" id="featured-lightbox-caption"></p>
        <p class="featured-lightbox__counter" id="featured-lightbox-counter" aria-live="polite"></p>
      </div>
      <button type="button" class="featured-lightbox__nav featured-lightbox__nav--next" id="featured-lightbox-next" aria-label="Next image">›</button>
    </div>

  </section>
)}

<style>
  .featured-collection {
    padding: var(--fc-pad, 5rem) 0 4rem;
    position: relative;
  }

  /* ── Header ── */
  .featured-collection__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .featured-collection__eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }

  .featured-collection__heading {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
  }

  /* ── Top row: hero + 2×2 ── */
  .featured-collection__top {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 6px;
    margin-bottom: 6px;
  }

  .featured-collection__grid2x2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 6px;
  }

  /* ── Bottom row: 2 tall cells ── */
  .featured-collection__bottom {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }

  /* ── Shared cell styles ── */
  .featured-cell {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: 3px;
    text-decoration: none;
    background: var(--bg-elevated);
  }

  .featured-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.65s var(--ease-out);
  }

  .featured-cell:hover img {
    transform: scale(1.05);
  }

  /* Hero tall */
  .featured-cell--hero {
    min-height: 540px;
  }

  /* 2×2 cells */
  .featured-cell--sm {
    aspect-ratio: auto;
  }

  /* Bottom tall cells */
  .featured-cell--tall {
    aspect-ratio: 3 / 4;
  }

  /* ── Hover overlay ── */
  .featured-cell__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.25rem 1.1rem;
    background: linear-gradient(to top, rgba(10, 6, 18, 0.82) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 3px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s var(--ease-out),
      transform 0.3s var(--ease-out);
  }

  .featured-cell:hover .featured-cell__overlay {
    opacity: 1;
    transform: translateY(0);
  }

  /* Also show overlay on focus (keyboard nav) */
  .featured-cell:focus-visible .featured-cell__overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-cell:focus-visible {
    outline: 2px solid var(--purple-500);
    outline-offset: 3px;
  }

  .featured-cell {
    cursor: pointer;
  }

  .featured-cell__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.01em;
  }

  .featured-cell__cat {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ── CTA ── */
  .featured-collection__cta {
    text-align: center;
    margin-top: 2.25rem;
  }

  .featured-collection__cta-link {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 3px;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out);
  }

  .featured-collection__cta-link:hover {
    color: var(--accent-bright);
    border-color: var(--border-strong);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .featured-collection__top {
      grid-template-columns: 1fr;
    }

    .featured-cell--hero {
      min-height: 420px;
    }

    .featured-collection__bottom {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .featured-collection__grid2x2 {
      grid-template-columns: 1fr 1fr;
    }

    .featured-collection__bottom {
      grid-template-columns: 1fr;
    }

    .featured-cell--tall {
      aspect-ratio: 4 / 3;
    }
  }

  /* ── Lightbox ── */
  .featured-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .featured-lightbox[hidden] {
    display: none !important;
  }
  .featured-lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: pointer;
  }
  .featured-lightbox__content {
    position: relative;
    z-index: 2;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .featured-lightbox__content img {
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease;
    transform-origin: center;
  }
  @media (hover: hover) {
    .featured-lightbox__content img {
      cursor: zoom-in;
    }
    .featured-lightbox__content img:hover {
      transform: scale(1.3);
    }
  }
  .featured-lightbox__caption {
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    text-align: center;
  }
  .featured-lightbox__counter {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin: 0;
  }
  .featured-lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .featured-lightbox__close:hover {
    background: rgba(0, 0, 0, 0.75);
    border-color: rgba(255, 255, 255, 0.5);
  }
  .featured-lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .featured-lightbox__nav:hover {
    background: rgba(0, 0, 0, 0.65);
    border-color: rgba(255, 255, 255, 0.5);
  }
  .featured-lightbox__nav--prev { left: 1rem; }
  .featured-lightbox__nav--next { right: 1rem; }
</style>

<script>
  (function () {
    var section = document.getElementById('featured');
    if (!section) return;
    var cells = section.querySelectorAll('.featured-cell');
    if (cells.length === 0) return;

    var lightbox = document.getElementById('featured-lightbox');
    var lightboxImg = document.getElementById('featured-lightbox-img');
    var lightboxCaption = document.getElementById('featured-lightbox-caption');
    var lightboxCounter = document.getElementById('featured-lightbox-counter');
    var lightboxPrev = document.getElementById('featured-lightbox-prev');
    var lightboxNext = document.getElementById('featured-lightbox-next');
    var lightboxClose = document.getElementById('featured-lightbox-close');
    var lightboxBackdrop = document.getElementById('featured-lightbox-backdrop');

    function buildList() {
      var list = [];
      cells.forEach(function (cell) {
        var img = cell.querySelector('img');
        var titleEl = cell.querySelector('.featured-cell__title');
        list.push({
          src: img ? img.src : '',
          title: titleEl ? titleEl.textContent : ''
        });
      });
      return list;
    }

    var currentList = [];
    var lightboxIndex = 0;

    function updateLightboxImage() {
      if (!lightboxImg || !currentList.length) return;
      var a = currentList[lightboxIndex];
      lightboxImg.src = a.src || '';
      lightboxImg.alt = a.title || 'Artwork';
      if (lightboxCaption) lightboxCaption.textContent = a.title || 'Untitled';
      if (lightboxCounter) lightboxCounter.textContent = (lightboxIndex + 1) + ' / ' + currentList.length;
      if (lightboxPrev) lightboxPrev.style.visibility = currentList.length <= 1 ? 'hidden' : 'visible';
      if (lightboxNext) lightboxNext.style.visibility = currentList.length <= 1 ? 'hidden' : 'visible';
    }

    function openLightbox(index) {
      currentList = buildList();
      lightboxIndex = index;
      updateLightboxImage();
      if (lightbox) {
        lightbox.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      document.addEventListener('keydown', lightboxKeydown);
    }

    function closeLightbox() {
      if (lightbox) {
        lightbox.hidden = true;
        document.body.style.overflow = '';
      }
      document.removeEventListener('keydown', lightboxKeydown);
    }

    function lightboxKeydown(e) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') {
        lightboxIndex = (lightboxIndex - 1 + currentList.length) % currentList.length;
        updateLightboxImage();
      }
      if (e.key === 'ArrowRight') {
        lightboxIndex = (lightboxIndex + 1) % currentList.length;
        updateLightboxImage();
      }
    }

    cells.forEach(function (cell, i) {
      cell.addEventListener('click', function (e) {
        e.preventDefault();
        openLightbox(i);
      });
    });

    if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
    if (lightboxBackdrop) lightboxBackdrop.addEventListener('click', closeLightbox);
    if (lightboxPrev) lightboxPrev.addEventListener('click', function () {
      lightboxIndex = (lightboxIndex - 1 + currentList.length) % currentList.length;
      updateLightboxImage();
    });
    if (lightboxNext) lightboxNext.addEventListener('click', function () {
      lightboxIndex = (lightboxIndex + 1) % currentList.length;
      updateLightboxImage();
    });
  })();
</script>
