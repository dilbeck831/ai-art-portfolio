---
/**
 * FeaturedCollection.astro
 * Mosaic layout: first piece large (2×2), next two tall (1×2), rest 1×1.
 *
 * Usage in index.astro:
 *   import FeaturedCollection from '../components/FeaturedCollection.astro';
 *   <FeaturedCollection artworks={featured} base={base} />
 */
import type { Artwork } from '../data/artworks';

interface Props {
  artworks: Artwork[];
  base: string;
}

const { artworks, base } = Astro.props;

const pieces = artworks.slice(0, 8);
---

<section class="featured-collection">
  <div class="fc-header">
    <div class="fc-header__left">
      <p class="fc-label">Selected Works</p>
      <h2 class="fc-title">Featured Collection</h2>
    </div>
    <a href={`${base}work/ai-art/`} class="fc-view-all">View All Works →</a>
  </div>

  <div class="fc-mosaic">
    {pieces.map((artwork, i) => (
      <a
        href={`${base}work/ai-art/#${artwork.slug}`}
        class={`fc-item fc-item--${i === 0 ? 'hero' : i <= 2 ? 'tall' : 'square'}`}
        data-index={i}
      >
        <img
          src={`${base}art/${artwork.image}`}
          alt={artwork.title}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
        <div class="fc-item__overlay">
          <div class="fc-item__info">
            <span class="fc-item__title">{artwork.title}</span>
            <span class="fc-item__category">
              {artwork.series.charAt(0).toUpperCase() + artwork.series.slice(1).replace('-', ' ')}
              {artwork.year ? ` · ${artwork.year}` : ''}
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="fc-cta">
    <a href={`${base}work/ai-art/`} class="fc-cta__link">
      <span>View All Works</span>
      <span class="fc-cta__arrow">→</span>
    </a>
  </div>
</section>

<style>
  .featured-collection {
    margin: calc(var(--space) * 4) 0;
  }

  .fc-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: calc(var(--space) * 1.5);
    gap: 1rem;
  }
  .fc-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin: 0 0 0.4rem 0;
  }
  .fc-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0;
  }
  .fc-view-all {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
    padding-bottom: 0.2rem;
    border-bottom: 1px solid transparent;
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }
  .fc-view-all:hover {
    color: var(--accent-bright);
    border-bottom-color: var(--accent-bright);
  }

  .fc-mosaic {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 280px 280px;
    gap: 3px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
  }

  .fc-item {
    position: relative;
    overflow: hidden;
    display: block;
    background: var(--bg-elevated);
    cursor: pointer;
    opacity: 0;
  }

  .fc-item--hero {
    grid-column: span 2;
    grid-row: span 2;
  }

  .fc-item--tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .fc-item--square {
    grid-column: span 1;
    grid-row: span 1;
  }

  .fc-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-out), filter 0.4s var(--ease-out);
    will-change: transform;
  }

  .fc-item__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 6, 18, 0.92) 0%,
      rgba(10, 6, 18, 0.4) 40%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.35s var(--ease-out);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
  }

  .fc-item__info {
    transform: translateY(8px);
    transition: transform 0.35s var(--ease-out);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .fc-item__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .fc-item--hero .fc-item__title {
    font-size: 1.3rem;
  }
  .fc-item__category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
  }

  .fc-item::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 2px;
    background: var(--gradient-primary);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
    pointer-events: none;
    z-index: 2;
  }

  .fc-item:hover img {
    transform: scale(1.06);
    filter: brightness(0.85);
  }
  .fc-item:hover .fc-item__overlay {
    opacity: 1;
  }
  .fc-item:hover .fc-item__info {
    transform: translateY(0);
  }
  .fc-item:hover::before {
    opacity: 1;
  }

  .fc-item:focus-visible {
    outline: 2px solid var(--purple-500);
    outline-offset: 2px;
    z-index: 3;
  }

  .fc-cta {
    margin-top: calc(var(--space) * 1.5);
    display: flex;
    justify-content: center;
  }
  .fc-cta__link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    transition:
      color 0.25s var(--ease-out),
      border-color 0.25s var(--ease-out),
      background 0.25s var(--ease-out),
      transform 0.25s var(--ease-spring);
  }
  .fc-cta__link:hover {
    color: var(--accent-bright);
    border-color: var(--border-strong);
    background: var(--surface-hover);
    transform: translateY(-2px);
  }
  .fc-cta__arrow {
    transition: transform 0.25s var(--ease-out);
  }
  .fc-cta__link:hover .fc-cta__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .fc-mosaic {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(4, 200px);
    }
    .fc-item--hero {
      grid-column: span 2;
      grid-row: span 2;
    }
    .fc-item--tall {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  @media (max-width: 560px) {
    .fc-mosaic {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(5, 160px);
    }
    .fc-item--hero {
      grid-column: span 2;
      grid-row: span 2;
    }
    .fc-item--tall,
    .fc-item--square {
      grid-column: span 1;
      grid-row: span 1;
    }
    .fc-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const mosaic = document.querySelector('.fc-mosaic');
  if (mosaic) {
    const items = mosaic.querySelectorAll('.fc-item');
    ScrollTrigger.create({
      trigger: mosaic,
      start: 'top 85%',
      onEnter: () => {
        gsap.to(items, {
          opacity: 1,
          duration: 0.55,
          stagger: { each: 0.08, from: 'start' },
          ease: 'power2.out',
        });
      },
      once: true,
    });
  }
</script>
