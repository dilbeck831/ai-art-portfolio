---
import type { Artwork } from '../data/artworks';

interface Props {
  artwork: Artwork;
  base?: string;
}
const { artwork, base = import.meta.env.BASE_URL } = Astro.props;
const img = (artwork as { image?: string; image_url?: string }).image_url ?? (artwork as { image?: string }).image;
const slug = (artwork as { slug?: string; id?: string }).slug ?? (artwork as { id?: string }).id ?? '';
const imageUrl = img?.startsWith('http') ? img : `${base}art/${img}`;
const videoUrl = (artwork as { video?: string }).video ? `${base}art/${(artwork as { video: string }).video}` : null;
---
<li class="art-card">
  <a href={`${base}work/ai-art/#${slug}`} class="art-card__link">
    <div class="art-card__media">
      {videoUrl ? (
        <video src={videoUrl} poster={imageUrl} muted loop playsinline />
      ) : (
        <img src={imageUrl} alt={artwork.title} loading="lazy" decoding="async" />
      )}
    </div>
    <div class="art-card__body">
      <h3 class="art-card__title">{artwork.title}</h3>
      {artwork.description && <p class="art-card__description">{artwork.description}</p>}
    </div>
  </a>
</li>

<style>
  .art-card__link {
    display: block;
    color: inherit;
  }
</style>
