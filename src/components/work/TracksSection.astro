---
import type { SunoTrack } from '../../data/music';
interface Props {
  tracks: SunoTrack[];
  embedBase?: string;
}
const { tracks, embedBase = 'https://suno.com/embed' } = Astro.props;
---
{tracks.length > 0 && (
  <section class="suno-embeds" aria-label="Suno tracks" data-suno-embed-base={embedBase}>
    <h2 class="section-title">Tracks</h2>
    <div class="suno-embeds__player-wrap" aria-live="polite">
      <iframe
        id="suno-embed-iframe"
        src={`${embedBase}/${tracks[0].id}?autoplay=1`}
        title={`${tracks[0].title} — Suno`}
        class="suno-embeds__iframe"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; fullscreen; gyroscope"
      />
    </div>
    <div class="suno-embeds__track-list" role="tablist" aria-label="Select a track">
      {tracks.map((track, i) => (
        <button
          type="button"
          class={`suno-embeds__track-btn ${i === 0 ? 'is-active' : ''}`}
          role="tab"
          aria-selected={i === 0}
          data-suno-id={track.id}
          data-suno-title={track.title}
        >
          {track.title}
        </button>
      ))}
    </div>
    <script>
      (function () {
        const container = document.querySelector('.suno-embeds');
        if (!container) return;
        const iframe = document.getElementById('suno-embed-iframe');
        const base = container.getAttribute('data-suno-embed-base');
        const buttons = container.querySelectorAll('.suno-embeds__track-btn');
        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-suno-id');
            const title = btn.getAttribute('data-suno-title');
            if (!id || !iframe || !base) return;
            iframe.src = base + '/' + id + '?autoplay=1';
            iframe.title = title + ' — Suno';
            buttons.forEach((b) => {
              b.classList.remove('is-active');
              b.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('is-active');
            btn.setAttribute('aria-selected', 'true');
          });
        });
      })();
    </script>
  </section>
)}
