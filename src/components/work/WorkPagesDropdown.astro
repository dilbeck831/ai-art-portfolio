---
/**
 * Work hub navigation: switch between main Work and Anotha Level (Archive).
 */
interface Props {
  current: 'work' | 'archive';
}
const { current } = Astro.props;
const base = import.meta.env.BASE_URL;
const baseNorm = base.endsWith('/') ? base : `${base}/`;
const workHref = `${baseNorm}work/`;
const archiveHref = `${baseNorm}work/anothalevel/`;
---

<div class="work-pages-dropdown">
  <label for="work-pages-select">Pages</label>
  <select id="work-pages-select" aria-label="Switch between Work and Archive">
    <option value={workHref} selected={current === 'work'}>Work</option>
    <option value={archiveHref} selected={current === 'archive'}>Archive</option>
  </select>
</div>

<script>
  const sel = document.getElementById('work-pages-select');
  sel?.addEventListener('change', () => {
    const v = (sel as HTMLSelectElement).value;
    if (v) window.location.href = v;
  });
</script>
