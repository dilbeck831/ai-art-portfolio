---
interface Props {
  sections: { title: string; body: string }[];
}
const { sections } = Astro.props;
---
<div class="process-block">
  {sections.map((s) => (
    <div class="process-block__item">
      <h3 class="process-block__title">{s.title}</h3>
      <p class="process-block__body">{s.body}</p>
    </div>
  ))}
</div>

<style>
  .process-block {
    display: flex;
    flex-direction: column;
    gap: var(--space);
  }
  .process-block__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 0.35rem 0;
  }
  .process-block__body {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }
</style>
