---
const base = import.meta.env.BASE_URL;

// Web URL always used on desktop (new tab). On mobile, appUrl opens the app when installed; fallback to web.
const links = [
  { label: 'X', href: 'https://x.com/TOXIQMYND', src: 'icons/x.png', appUrl: 'twitter://user?screen_name=TOXIQMYND' },
  { label: 'Objkt', href: 'https://objkt.com/users/tz2Rxe2FJYVo2hPn6UPg1GX33enNwrNw9uUD', src: 'icons/objkt.png' },
  { label: 'TikTok', href: 'https://tiktok.com/@toxiqmynd', src: 'icons/tiktok.png', appUrl: 'tiktok://user?username=toxiqmynd' },
  { label: 'Webbie', href: 'https://webbiesocial.com/stacks/toxiqmynd', src: 'icons/webbie.png' },
  { label: 'Instagram', href: 'https://www.instagram.com/TOXIQMYND', src: 'icons/instagram.png', appUrl: 'instagram://user?username=TOXIQMYND' },
  { label: 'Suno', href: 'https://suno.com/@toxiqmynd', src: 'icons/suno.png' },
];
---

<nav class="social-icons" aria-label="Social media links">
  {links.map(({ label, href, src, appUrl }) => (
    <a
      href={href}
      class="social-icons__link"
      data-app-url={appUrl || undefined}
      data-web-url={href}
      aria-label={label}
      title={label}
      target="_blank"
      rel="noopener noreferrer"
    >
      <img src={base + src} alt="" width="24" height="24" loading="lazy" />
    </a>
  ))}
</nav>

<script>
  (function () {
    const socialLinks = document.querySelectorAll('.social-icons__link[data-app-url]');
    const mobile = window.matchMedia('(max-width: 700px)');

    function handleClick(e: Event) {
      if (!mobile.matches) return; // desktop: let default (new tab) happen
      const link = (e.currentTarget as HTMLAnchorElement);
      const appUrl = link.getAttribute('data-app-url');
      const webUrl = link.getAttribute('data-web-url');
      if (!appUrl || !webUrl) return;
      e.preventDefault();
      const start = Date.now();
      const fallback = () => {
        if (Date.now() - start < 2500) window.location.href = webUrl;
      };
      window.location.href = appUrl;
      setTimeout(fallback, 1500); // if app didn't open, open web
    }

    socialLinks.forEach((el) => el.addEventListener('click', handleClick));
  })();
</script>

<style>
  .social-icons {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .social-icons__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--text-muted);
    opacity: 0.55;
    text-decoration: none;
    transition:
      color 0.2s var(--ease-out),
      opacity 0.2s var(--ease-out),
      background 0.2s var(--ease-out);
  }

  .social-icons__link:hover {
    color: var(--accent);
    opacity: 1;
    background: rgba(139, 92, 246, 0.1);
  }

  .social-icons__link img {
    width: 24px;
    height: 24px;
    display: block;
    object-fit: contain;
  }

  .social-icons__link:focus-visible {
    outline: 2px solid var(--purple-500);
    outline-offset: 4px;
  }
</style>
