---

<nav class="social-icons" aria-label="Social media links">
  {links.map(({ label, href, svg }) => (
    <a
      href={href}
      class="social-icons__link"
      aria-label={label}
      title={label}
      target="_blank"
      rel="noopener noreferrer"
      set:html={svg}
    />
  ))}
</nav>

<style>
  .social-icons {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .social-icons__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--text-muted);
    opacity: 0.55;
    text-decoration: none;
    transition:
      color 0.2s var(--ease-out),
      opacity 0.2s var(--ease-out),
      background 0.2s var(--ease-out);
  }

  .social-icons__link:hover {
    color: var(--accent);
    opacity: 1;
    background: rgba(139, 92, 246, 0.1);
  }

  .social-icons__link :global(svg) {
    width: 15px;
    height: 15px;
    display: block;
    flex-shrink: 0;
  }

  .social-icons__link:focus-visible {
    outline: 2px solid var(--purple-500);
    outline-offset: 4px;
  }
</style>
