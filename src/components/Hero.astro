---
import SocialIcons from './SocialIcons.astro';

interface HeroImage {
  src: string;
  alt: string;
}

interface Props {
  /** Single hero image (legacy). Ignored if images is provided. */
  image?: HeroImage | null;
  /** Up to 3 images for Z-space carousel. When length >= 2, carousel is shown. */
  images?: HeroImage[];
  /** Profile image URL for mobile hero (e.g. artist photo). Circular crop. */
  profileImageUrl?: string | null;
  /** Brief description for mobile hero (editable in meta.ts). */
  heroDescription?: string;
  base?: string;
  currentPath?: string;
}

const { image = null, images = null, profileImageUrl = null, heroDescription = '', base = '/', currentPath = '' } = Astro.props;
const carouselImages = images && images.length >= 2 ? images.slice(0, 3) : null;
const singleImage = carouselImages ? null : (image || (images && images[0]) || null);
const isActive = (path: string) => (path === base ? currentPath === base || currentPath === base.replace(/\/$/, '') : currentPath.startsWith(path));
const navLinks = [
  { href: `${base}work/`, label: 'Work' },
  { href: `${base}work/ai-art/`, label: 'AI Art' },
  { href: `${base}work/music/`, label: 'Music' },
  { href: `${base}work/ux/`, label: 'UI/UX' },
  { href: `${base}lab/`, label: 'Lab' },
  { href: `${base}about/`, label: 'About' },
];
---

<header class="hero" id="hero" aria-label="Hero">
  <!-- Subtle motion gradients (background) -->
  <div class="hero__gradients" aria-hidden="true">
    <div class="hero__gradient hero__gradient--1"></div>
    <div class="hero__gradient hero__gradient--2"></div>
    <div class="hero__gradient hero__gradient--3"></div>
  </div>

  <!-- Desktop: text left, image right -->
  <div class="hero__desktop">
    <div class="hero__text">
      <p class="hero__label">AI Art · UI/UX · The Lab</p>
      <h1 class="hero__title">TØX!Q</h1>
      <p class="hero__subline">Where vision becomes obsidian</p>
    </div>
    <div class="hero__image-wrap">
      {carouselImages ? (
        <div class="hero__carousel" id="hero-carousel" aria-roledescription="carousel" aria-label="Hero images">
          <div class="hero__carousel-track">
            {carouselImages.map((img, i) => (
              <div class="hero__slide" data-slide-index={i} aria-hidden="true">
                <img src={img.src} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" width="800" height="1000" />
              </div>
            ))}
          </div>
          <button type="button" class="hero__carousel-btn hero__carousel-btn--prev" aria-label="Previous image" title="Previous">
            <span aria-hidden="true">‹</span>
          </button>
          <button type="button" class="hero__carousel-btn hero__carousel-btn--next" aria-label="Next image" title="Next">
            <span aria-hidden="true">›</span>
          </button>
          <div class="hero__carousel-controls">
            <div class="hero__carousel-dots" role="tablist" aria-label="Slide index">
              {carouselImages.map((_, i) => (
                <button type="button" class="hero__carousel-dot" role="tab" aria-selected={i === 0} aria-label={`Image ${i + 1}`} data-index={i}></button>
              ))}
            </div>
            <button type="button" class="hero__carousel-pause" id="hero-carousel-pause" aria-label="Pause auto-rotate" title="Pause" aria-pressed="false">
              <span class="hero__carousel-pause-icon hero__carousel-pause-icon--pause" aria-hidden="true">⏸</span>
              <span class="hero__carousel-pause-icon hero__carousel-pause-icon--play" aria-hidden="true" hidden>▶</span>
            </button>
          </div>
        </div>
      ) : singleImage ? (
        <img src={singleImage.src} alt={singleImage.alt} class="hero__image" loading="eager" decoding="async" width="800" height="1000" />
      ) : (
        <div class="hero__image-placeholder" aria-hidden="true"></div>
      )}
    </div>
  </div>

  <!-- Mobile only: profile, name, description, social, Menu accordion -->
  <div class="hero__mobile">
    <a href={base} class="hero__mobile-profile" aria-label="Home">
      {profileImageUrl ? (
        <img src={profileImageUrl} alt="" class="hero__mobile-avatar" width="160" height="160" loading="eager" decoding="async" />
      ) : (
        <div class="hero__mobile-avatar-placeholder" aria-hidden="true"></div>
      )}
    </a>
    <h1 class="hero__mobile-name">TØX!Q</h1>
    {heroDescription && <p class="hero__mobile-desc">{heroDescription}</p>}
    <div class="hero__mobile-social">
      <SocialIcons />
    </div>
    <div class="hero__menu-accordion">
      <button type="button" class="hero__menu-btn" aria-expanded="false" aria-controls="hero-menu-nav" id="hero-menu-btn">
        Menu
      </button>
      <nav id="hero-menu-nav" class="hero__menu-nav" aria-label="Main" hidden>
        <ul class="hero__menu-list">
          {navLinks.map(({ href, label }) => (
            <li><a href={href} class:list={['hero__menu-link', isActive(href) && 'hero__menu-link--active']}>{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    min-height: 480px;
    overflow: visible;
    padding: 0;
    max-width: var(--max-width, 1400px);
    margin: 0 auto;
    text-align: left;
    background: none;
  }

  /* Desktop: grid layout */
  .hero__desktop {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.5fr 1.5fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
    min-height: 80vh;
    min-height: 80dvh;
  }

  @media (max-width: 700px) {
    .hero__desktop {
      display: none;
    }
  }

  /* Mobile: stacked profile, name, desc, social, menu (show at 700px and below) */
  .hero__mobile {
    display: none;
    position: relative;
    z-index: 1;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem 1.5rem;
    min-height: 50dvh;
  }

  @media (max-width: 700px) {
    .hero__mobile {
      display: flex;
    }
  }

  .hero__mobile-profile {
    display: block;
    margin-bottom: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .hero__mobile-avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 3px solid rgba(139, 92, 246, 0.4);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .hero__mobile-avatar-placeholder {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: rgba(139, 92, 246, 0.2);
    border: 3px solid rgba(139, 92, 246, 0.3);
  }

  .hero__mobile-name {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: var(--text);
    line-height: 1.1;
  }

  .hero__mobile-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 320px;
    margin: 0 0 1.25rem;
  }

  .hero__mobile-social {
    margin-bottom: 1.5rem;
  }

  .hero__mobile-social :global(.social-icons) {
    justify-content: center;
  }

  /* Menu accordion */
  .hero__menu-accordion {
    width: 100%;
    max-width: 320px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .hero__menu-btn {
    width: 100%;
    padding: 0.875rem 1.25rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: left;
    color: var(--text);
    background: var(--surface);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.2s;
  }

  .hero__menu-btn:hover {
    background: var(--surface-hover);
  }

  .hero__menu-btn::after {
    content: '';
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.2s;
  }

  .hero__menu-btn[aria-expanded="true"]::after {
    transform: rotate(-135deg);
  }

  .hero__menu-nav {
    border-top: 1px solid var(--border);
  }

  .hero__menu-nav[hidden] {
    display: none !important;
  }

  .hero__menu-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
  }

  .hero__menu-link {
    display: block;
    padding: 0.5rem 1.25rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .hero__menu-link:hover,
  .hero__menu-link--active {
    color: var(--accent-bright);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__gradient {
      animation: none !important;
      opacity: 0.5;
    }
  }

  /* ----- Motion gradients (background) ----- */
  .hero__gradients {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: visible;
  }

  .hero__gradient {
    position: absolute;
    border-radius: 50%;
    opacity: 0;
    /* Large centered blobs so they bleed past the hero with no visible edges */
    width: 160vmax;
    height: 160vmax;
    left: 50%;
    top: 50%;
    margin-left: -80vmax;
    margin-top: -80vmax;
  }

  .hero__gradient--1 {
    background: radial-gradient(
      ellipse 70% 70% at 50% 50%,
      rgba(88, 28, 135, 0.2) 0%,
      rgba(30, 27, 75, 0.08) 40%,
      transparent 70%
    );
    animation: hero-gradient-1 18s ease-in-out infinite;
  }

  .hero__gradient--2 {
    background: radial-gradient(
      ellipse 60% 80% at 60% 40%,
      rgba(139, 92, 246, 0.15) 0%,
      transparent 55%
    );
    animation: hero-gradient-2 22s ease-in-out infinite;
    animation-delay: -4s;
  }

  .hero__gradient--3 {
    background: radial-gradient(
      ellipse 80% 60% at 30% 70%,
      rgba(30, 27, 75, 0.12) 0%,
      transparent 60%
    );
    animation: hero-gradient-3 20s ease-in-out infinite;
    animation-delay: -8s;
  }

  @keyframes hero-gradient-1 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    50% { transform: translate(3%, -2%) scale(1.05); opacity: 0.8; }
  }

  @keyframes hero-gradient-2 {
    0%, 100% { transform: translate(-2%, 1%) scale(1); opacity: 0.5; }
    50% { transform: translate(2%, -3%) scale(1.08); opacity: 0.7; }
  }

  @keyframes hero-gradient-3 {
    0%, 100% { transform: translate(1%, -1%) scale(1); opacity: 0.5; }
    50% { transform: translate(-3%, 2%) scale(1.03); opacity: 0.7; }
  }

  /* ----- Text (desktop) ----- */
  .hero__text {
    position: relative;
    max-width: 32rem;
  }

  .hero__text::before {
    content: "";
    position: absolute;
    inset: -1rem;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.2) 0%, transparent 50%);
    border-radius: 12px;
    z-index: -1;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none;
  }

  .hero__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hero-text-muted, rgba(255, 255, 255, 0.7));
    margin: 0 0 0.5rem 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 0.5rem 0;
    background: var(--gradient-primary, linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.9) 100%));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: none;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.8));
  }

  .hero__subline {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    color: var(--hero-text-subline, rgba(255, 255, 255, 0.95));
    margin: 0;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  /* ----- Image (right) ----- */
  .hero__image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }

  .hero__image {
    width: 100%;
    max-width: 520px;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .hero__image-placeholder {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 4 / 5;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: var(--radius-lg, 16px);
  }

  /* ----- Z-space carousel ----- */
  .hero__carousel {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__carousel-track {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 4 / 5;
    max-height: 85vh;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.5s ease, box-shadow 0.5s ease;
    pointer-events: none;
  }

  .hero__slide.is-left {
    transform: translateX(-28%) scale(0.88);
    z-index: 1;
    opacity: 0.92;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.05);
    pointer-events: none;
  }

  .hero__slide.is-center {
    transform: translateX(0) scale(1);
    z-index: 2;
    opacity: 1;
    box-shadow: 0px 0px 50px 15px rgb(0 0 0 / 60%), 0 0 0 1px rgb(176 132 255 / 48%);
    pointer-events: auto;
  }

  .hero__slide.is-right {
    transform: translateX(28%) scale(0.88);
    z-index: 1;
    opacity: 0.92;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.05);
    pointer-events: none;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-lg, 16px);
  }

  .hero__carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    font-size: 1.5rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
  }

  .hero__carousel-btn:hover {
    background: rgba(0, 0, 0, 0.6);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .hero__carousel-btn--prev { left: -8px; }
  .hero__carousel-btn--next { right: -8px; }

  .hero__carousel-controls {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
  }

  .hero__carousel-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .hero__carousel-pause {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(0, 0, 0, 0.35);
    color: #fff;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .hero__carousel-pause:hover {
    background: rgba(0, 0, 0, 0.55);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hero__carousel-pause[aria-pressed="true"] .hero__carousel-pause-icon--pause {
    display: none;
  }

  .hero__carousel-pause[aria-pressed="true"] .hero__carousel-pause-icon--play {
    display: inline !important;
  }

  .hero__carousel-pause-icon--play {
    display: none;
  }

  .hero__carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.25);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .hero__carousel-dot:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .hero__carousel-dot[aria-selected="true"] {
    background: var(--accent-bright, #c4b5fd);
    border-color: var(--accent-bright, #c4b5fd);
    transform: scale(1.2);
  }
</style>

<script>
  import gsap from 'gsap';

  function initCarousel() {
    const carousel = document.getElementById('hero-carousel');
    if (!carousel) return;

    const track = carousel.querySelector('.hero__carousel-track');
    const slides = Array.from(carousel.querySelectorAll('.hero__slide'));
    const prevBtn = carousel.querySelector('.hero__carousel-btn--prev');
    const nextBtn = carousel.querySelector('.hero__carousel-btn--next');
    const dots = Array.from(carousel.querySelectorAll('.hero__carousel-dot'));
    const pauseBtn = document.getElementById('hero-carousel-pause');
    const total = slides.length;
    if (total < 2) return;

    let currentIndex = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;
    let paused = false;
    const AUTO_MS = 5000;

    function slotFor(slideIndex: number): 'left' | 'center' | 'right' {
      const diff = (slideIndex - currentIndex + total) % total;
      if (diff === 0) return 'center';
      if (total === 2) return diff === 1 ? 'right' : 'left';
      if (diff === 1) return 'right';
      return 'left';
    }

    function updateSlots() {
      slides.forEach((el, i) => {
        const slot = slotFor(i);
        el.classList.remove('is-left', 'is-center', 'is-right');
        el.classList.add(`is-${slot}`);
        el.setAttribute('aria-hidden', slot === 'center' ? 'false' : 'true');
      });
      dots.forEach((dot, i) => {
        dot.setAttribute('aria-selected', i === currentIndex ? 'true' : 'false');
      });
    }

    function goTo(index: number) {
      currentIndex = (index + total) % total;
      updateSlots();
      resetAuto();
    }

    function next() {
      goTo(currentIndex + 1);
    }

    function prev() {
      goTo(currentIndex - 1);
    }

    function resetAuto() {
      if (autoTimer) clearInterval(autoTimer);
      autoTimer = null;
      if (!paused) autoTimer = setInterval(next, AUTO_MS);
    }

    function setPaused(value: boolean) {
      paused = value;
      if (pauseBtn) {
        pauseBtn.setAttribute('aria-pressed', String(value));
        pauseBtn.setAttribute('aria-label', value ? 'Play auto-rotate' : 'Pause auto-rotate');
        pauseBtn.setAttribute('title', value ? 'Play' : 'Pause');
      }
      if (paused && autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      } else if (!paused) {
        resetAuto();
      }
    }

    updateSlots();
    resetAuto();

    nextBtn?.addEventListener('click', next);
    prevBtn?.addEventListener('click', prev);
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });
    pauseBtn?.addEventListener('click', () => setPaused(!paused));

    carousel.addEventListener('mouseenter', () => {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    });
    carousel.addEventListener('mouseleave', () => {
      if (!paused) resetAuto();
    });
  }

  function initHero() {
    const hero = document.getElementById('hero');
    if (!hero) return;

    const label = hero.querySelector('.hero__label');
    const title = hero.querySelector('.hero__title');
    const subline = hero.querySelector('.hero__subline');

    if (label && title && subline) {
      gsap.set([label, title, subline], { opacity: 0, y: 20 });
      gsap.to([label, title, subline], {
        opacity: 1,
        y: 0,
        duration: 0.9,
        stagger: 0.12,
        delay: 0.2,
        ease: 'power2.out',
      });
    }

    const menuBtn = document.getElementById('hero-menu-btn');
    const menuNav = document.getElementById('hero-menu-nav');
    if (menuBtn && menuNav) {
      menuBtn.addEventListener('click', () => {
        const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
        menuBtn.setAttribute('aria-expanded', String(!expanded));
        menuNav.hidden = expanded;
      });
    }

    initCarousel();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
