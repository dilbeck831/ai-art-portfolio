---
import SocialIcons from './SocialIcons.astro';

interface HeroImage {
  src: string;
  alt: string;
}

interface Props {
  /** Single hero image shown to the right of the text. From getHomepageHeroArtwork() in artworks.ts. */
  image?: HeroImage | null;
  /** Profile image URL for mobile hero (e.g. artist photo). Circular crop. */
  profileImageUrl?: string | null;
  /** Brief description for mobile hero (editable in meta.ts). */
  heroDescription?: string;
  base?: string;
  currentPath?: string;
}

const { image = null, profileImageUrl = null, heroDescription = '', base = '/', currentPath = '' } = Astro.props;
const isActive = (path: string) => (path === base ? currentPath === base || currentPath === base.replace(/\/$/, '') : currentPath.startsWith(path));
const navLinks = [
  { href: base, label: 'Home' },
  { href: `${base}work/`, label: 'Work' },
  { href: `${base}work/ai-art/`, label: 'AI Art' },
  { href: `${base}work/music/`, label: 'Music' },
  { href: `${base}work/ux/`, label: 'UI/UX' },
  { href: `${base}lab/`, label: 'Lab' },
  { href: `${base}about/`, label: 'About' },
  { href: `${base}contact/`, label: 'Contact' },
];
---

<header class="hero" id="hero" aria-label="Hero">
  <!-- Subtle motion gradients (background) -->
  <div class="hero__gradients" aria-hidden="true">
    <div class="hero__gradient hero__gradient--1"></div>
    <div class="hero__gradient hero__gradient--2"></div>
    <div class="hero__gradient hero__gradient--3"></div>
  </div>

  <!-- Desktop: text left, image right -->
  <div class="hero__desktop">
    <div class="hero__text">
      <p class="hero__label">AI Art · UI/UX · The Lab</p>
      <h1 class="hero__title">TØX!Q</h1>
      <p class="hero__subline">Where vision becomes obsidian</p>
    </div>
    <div class="hero__image-wrap">
      {image ? (
        <img src={image.src} alt={image.alt} class="hero__image" loading="eager" decoding="async" width="800" height="1000" />
      ) : (
        <div class="hero__image-placeholder" aria-hidden="true"></div>
      )}
    </div>
  </div>

  <!-- Mobile only: profile, name, description, social, Menu accordion -->
  <div class="hero__mobile">
    <div class="hero__mobile-profile">
      {profileImageUrl ? (
        <img src={profileImageUrl} alt="" class="hero__mobile-avatar" width="160" height="160" loading="eager" decoding="async" />
      ) : (
        <div class="hero__mobile-avatar-placeholder" aria-hidden="true"></div>
      )}
    </div>
    <h1 class="hero__mobile-name">TØX!Q</h1>
    {heroDescription && <p class="hero__mobile-desc">{heroDescription}</p>}
    <div class="hero__mobile-social">
      <SocialIcons />
    </div>
    <div class="hero__menu-accordion">
      <button type="button" class="hero__menu-btn" aria-expanded="false" aria-controls="hero-menu-nav" id="hero-menu-btn">
        Menu
      </button>
      <nav id="hero-menu-nav" class="hero__menu-nav" aria-label="Main" hidden>
        <ul class="hero__menu-list">
          {navLinks.map(({ href, label }) => (
            <li><a href={href} class:list={['hero__menu-link', isActive(href) && 'hero__menu-link--active']}>{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    min-height: 480px;
    overflow: hidden;
    padding: 0;
    max-width: var(--max-width, 1400px);
    margin: 0 auto;
    text-align: left;
    background: none;
  }

  /* Desktop: grid layout */
  .hero__desktop {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
    min-height: 80vh;
    min-height: 80dvh;
  }

  @media (max-width: 700px) {
    .hero__desktop {
      display: none;
    }
  }

  /* Mobile: stacked profile, name, desc, social, menu (show at 700px and below) */
  .hero__mobile {
    display: none;
    position: relative;
    z-index: 1;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem 1.5rem;
    min-height: 80vh;
    min-height: 80dvh;
  }

  @media (max-width: 700px) {
    .hero__mobile {
      display: flex;
    }
  }

  .hero__mobile-profile {
    margin-bottom: 1rem;
  }

  .hero__mobile-avatar {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 3px solid rgba(139, 92, 246, 0.4);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .hero__mobile-avatar-placeholder {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: rgba(139, 92, 246, 0.2);
    border: 3px solid rgba(139, 92, 246, 0.3);
  }

  .hero__mobile-name {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: var(--text);
    line-height: 1.1;
  }

  .hero__mobile-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 320px;
    margin: 0 0 1.25rem;
  }

  .hero__mobile-social {
    margin-bottom: 1.5rem;
  }

  .hero__mobile-social :global(.social-icons) {
    justify-content: center;
  }

  /* Menu accordion */
  .hero__menu-accordion {
    width: 100%;
    max-width: 320px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .hero__menu-btn {
    width: 100%;
    padding: 0.875rem 1.25rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: left;
    color: var(--text);
    background: var(--surface);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.2s;
  }

  .hero__menu-btn:hover {
    background: var(--surface-hover);
  }

  .hero__menu-btn::after {
    content: '';
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.2s;
  }

  .hero__menu-btn[aria-expanded="true"]::after {
    transform: rotate(-135deg);
  }

  .hero__menu-nav {
    border-top: 1px solid var(--border);
  }

  .hero__menu-nav[hidden] {
    display: none !important;
  }

  .hero__menu-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
  }

  .hero__menu-link {
    display: block;
    padding: 0.5rem 1.25rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .hero__menu-link:hover,
  .hero__menu-link--active {
    color: var(--accent-bright);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__gradient {
      animation: none !important;
      opacity: 0.5;
    }
  }

  /* ----- Motion gradients (background) ----- */
  .hero__gradients {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero__gradient {
    position: absolute;
    border-radius: 50%;
    opacity: 0;
  }

  .hero__gradient--1 {
    width: 120%;
    height: 120%;
    top: -20%;
    left: -30%;
    background: radial-gradient(
      ellipse 70% 70% at 50% 50%,
      rgba(88, 28, 135, 0.2) 0%,
      rgba(30, 27, 75, 0.08) 40%,
      transparent 70%
    );
    animation: hero-gradient-1 18s ease-in-out infinite;
  }

  .hero__gradient--2 {
    width: 100%;
    height: 100%;
    top: -10%;
    right: -20%;
    background: radial-gradient(
      ellipse 60% 80% at 60% 40%,
      rgba(139, 92, 246, 0.15) 0%,
      transparent 55%
    );
    animation: hero-gradient-2 22s ease-in-out infinite;
    animation-delay: -4s;
  }

  .hero__gradient--3 {
    width: 80%;
    height: 80%;
    bottom: -15%;
    left: -10%;
    background: radial-gradient(
      ellipse 80% 60% at 30% 70%,
      rgba(30, 27, 75, 0.12) 0%,
      transparent 60%
    );
    animation: hero-gradient-3 20s ease-in-out infinite;
    animation-delay: -8s;
  }

  @keyframes hero-gradient-1 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    50% { transform: translate(3%, -2%) scale(1.05); opacity: 0.8; }
  }

  @keyframes hero-gradient-2 {
    0%, 100% { transform: translate(-2%, 1%) scale(1); opacity: 0.5; }
    50% { transform: translate(2%, -3%) scale(1.08); opacity: 0.7; }
  }

  @keyframes hero-gradient-3 {
    0%, 100% { transform: translate(1%, -1%) scale(1); opacity: 0.5; }
    50% { transform: translate(-3%, 2%) scale(1.03); opacity: 0.7; }
  }

  /* ----- Text (desktop) ----- */
  .hero__text {
    position: relative;
    max-width: 32rem;
  }

  .hero__text::before {
    content: "";
    position: absolute;
    inset: -1rem;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.2) 0%, transparent 50%);
    border-radius: 12px;
    z-index: -1;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none;
  }

  .hero__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hero-text-muted, rgba(255, 255, 255, 0.7));
    margin: 0 0 0.5rem 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 0.5rem 0;
    background: var(--gradient-primary, linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.9) 100%));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: none;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.8));
  }

  .hero__subline {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    color: var(--hero-text-subline, rgba(255, 255, 255, 0.95));
    margin: 0;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  /* ----- Image (right) ----- */
  .hero__image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }

  .hero__image {
    width: 100%;
    max-width: 520px;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .hero__image-placeholder {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 4 / 5;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: var(--radius-lg, 16px);
  }
</style>

<script>
  import gsap from 'gsap';

  function initHero() {
    const hero = document.getElementById('hero');
    if (!hero) return;

    const label = hero.querySelector('.hero__label');
    const title = hero.querySelector('.hero__title');
    const subline = hero.querySelector('.hero__subline');

    if (label && title && subline) {
      gsap.set([label, title, subline], { opacity: 0, y: 20 });
      gsap.to([label, title, subline], {
        opacity: 1,
        y: 0,
        duration: 0.9,
        stagger: 0.12,
        delay: 0.2,
        ease: 'power2.out',
      });
    }

    const menuBtn = document.getElementById('hero-menu-btn');
    const menuNav = document.getElementById('hero-menu-nav');
    if (menuBtn && menuNav) {
      menuBtn.addEventListener('click', () => {
        const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
        menuBtn.setAttribute('aria-expanded', String(!expanded));
        menuNav.hidden = expanded;
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
