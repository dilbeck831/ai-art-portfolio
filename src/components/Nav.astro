---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;
const workActive = currentPath.startsWith(base + 'work/');
const labActive = currentPath.startsWith(base + 'lab/');
const isActive = (path: string) => (path === base ? currentPath === base || currentPath === base.replace(/\/$/, '') : currentPath.startsWith(path));
---
<nav class="nav" aria-label="Main">
  <a href={base} class={isActive(base) ? 'nav__link nav__link--active' : 'nav__link'}>Home</a>
  <a href={`${base}work/`} class={`nav__link ${workActive ? 'nav__link--active' : ''}`}>Work</a>
  <a href={`${base}lab/`} class={`nav__link ${labActive ? 'nav__link--active' : ''}`}>Lab</a>
  <a href={`${base}about/`} class={isActive(base + 'about/') ? 'nav__link nav__link--active' : 'nav__link'}>About</a>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .nav__link {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav__link:hover,
  .nav__link--active {
    color: var(--text);
  }
</style>
