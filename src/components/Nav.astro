---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;
const workActive = currentPath.startsWith(base + 'work/');
const labActive = currentPath.startsWith(base + 'lab/');
const isActive = (path: string) => (path === base ? currentPath === base || currentPath === base.replace(/\/$/, '') : currentPath.startsWith(path));
---
<nav class="nav" aria-label="Main">
  <a href={base} class={isActive(base) ? 'nav__link nav__link--active' : 'nav__link'}>Home</a>
  <div class="nav__dropdown">
    <a href={`${base}work/`} class={`nav__link ${workActive ? 'nav__link--active' : ''}`}>Work</a>
    <ul class="nav__sub">
      <li><a href={`${base}work/ai-art/`}>AI Art</a></li>
      <li><a href={`${base}work/music/`}>Music</a></li>
      <li><a href={`${base}work/ux/`}>UI/UX</a></li>
    </ul>
  </div>
  <a href={`${base}lab/`} class={`nav__link ${labActive ? 'nav__link--active' : ''}`}>Lab</a>
  <a href={`${base}about/`} class={isActive(base + 'about/') ? 'nav__link nav__link--active' : 'nav__link'}>About</a>
  <a href={`${base}contact/`} class={isActive(base + 'contact/') ? 'nav__link nav__link--active' : 'nav__link'}>Contact</a>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .nav__link {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav__link:hover,
  .nav__link--active {
    color: var(--text);
  }
  .nav__dropdown {
    position: relative;
  }
  .nav__dropdown:hover .nav__sub {
    opacity: 1;
    visibility: visible;
  }
  .nav__sub {
    position: absolute;
    top: 100%;
    left: 0;
    margin: 0.25rem 0 0 0;
    padding: 0.5rem 0;
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    min-width: 140px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
    z-index: 20;
  }
  .nav__sub a {
    display: block;
    padding: 0.4rem 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .nav__sub a:hover {
    color: var(--text);
    background: var(--surface-hover);
  }
</style>
